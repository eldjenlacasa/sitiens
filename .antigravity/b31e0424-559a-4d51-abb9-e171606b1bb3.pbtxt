        }
        lines {
          text: "  // Reduction savings"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const savedHours = Math.round(current.sufferingHours * (reductionTarget / 100));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const savedCo2 = parseFloat((current.co2 * (reductionTarget / 100)).toFixed(1));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const savedWater = Math.round(current.water * (reductionTarget / 100));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const savedLand = parseFloat((current.land * (reductionTarget / 100)).toFixed(1));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Equivalencies:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // - 1 shower = 60 Liters"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // - 1 Tree stores ~22kg of CO2 per year"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // - 1 m2 land = Area preserved"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const equivalentShowers = Math.round(savedWater / 60);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const equivalentTrees = parseFloat((savedCo2 / (22 / 52)).toFixed(1)); // tree/week equivalents"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
