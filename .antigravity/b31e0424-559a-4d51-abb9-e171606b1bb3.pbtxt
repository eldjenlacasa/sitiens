    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \"react\";\nimport { DILEMMAS_DATA, DilemmaDetail, ConsensusType } from \"../types\";\nimport { \n  Info, \n  HelpCircle, \n  CheckCircle, \n  XCircle, \n  AlertTriangle, \n  Eye, \n  Bot, \n  Bookmark, \n  ChevronDown \n} from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\ninterface ExcusesDilemmasProps {\n  onSelectForAI: (text: string) => void;\n}\n\nexport default function ExcusesDilemmas({ onSelectForAI }: ExcusesDilemmasProps) {\n  const [selectedCategory, setSelectedCategory] = useState<ConsensusType | \"ALL\">(\"ALL\");\n  const [expandedId, setExpandedId] = useState<string | null>(\"leones-carne\");\n\n  const getConsensusBadge = (type: ConsensusType) => {\n    switch (type) {\n      case \"CONSENSO\":\n        return {\n          label: \"Consenso Absoluto\",\n          classes: \"bg-emerald-500/10 text-emerald-400 border border-emerald-500/30\",\n          icon: <CheckCircle className=\"w-3.5 h-3.5\" />\n        };\n      case \"ESCENARIO_GRIS\":\n        return {\n          label: \"Escenario Gris\",\n          classes: \"bg-zinc-500/10 text-zinc-400 border border-zinc-500/30\",\n          icon: <HelpCircle className=\"w-3.5 h-3.5\" />\n        };\n      case \"DILEMA\":\n        return {\n          label: \"Dilema Filos\303\263fico\",\n          classes: \"bg-amber-500/10 text-amber-400 border border-amber-500/20\",\n          icon: <AlertTriangle className=\"w-3.5 h-3.5\" />\n        };\n      case \"FALACIA\":\n        return {\n          label: \"Falacia Refutada\",\n          classes: \"bg-red-500/10 text-red-400 border border-red-500/30\",\n          icon: <XCircle className=\"w-3.5 h-3.5\" />\n        };\n    }\n  };\n\n  const getFilterButtonClass = (cat: ConsensusType | \"ALL\") => {\n    const base = \"px-4 py-2 text-xs font-mono rounded-full border transition-all cursor-pointer\";\n    if (selectedCategory === cat) {\n      if (cat === \"FALACIA\") return `${base} bg-red-500/20 text-red-300 border-red-500/50`;\n      if (cat === \"DILEMA\") return `${base} bg-amber-500/20 text-amber-300 border-amber-500/45`;\n      if (cat === \"ESCENARIO_GRIS\") return `${base} bg-zinc-650 text-white border-zinc-700`;\n      if (cat === \"CONSENSO\") return `${base} bg-emerald-500/20 text-emerald-300 border-emerald-500/50`;\n      return `${base} bg-white text-zinc-950 border-white`;\n    }\n    return `${base} bg-zinc-900 text-zinc-400 border-zinc-800 hover:border-zinc-700 hover:text-zinc-200`;\n  };\n\n  const filteredDilemmas = selectedCategory === \"ALL\" \n    ? DILEMMAS_DATA \n    : DILEMMAS_DATA.filter((d) => d.consensus === selectedCategory);\n\n  return (\n    <div id=\"ethics-dilemmas-view\" className=\"space-y-8 w-full max-w-6xl mx-auto\">\n      {/* Narrative Intro */}\n      <div className=\"bg-zinc-950/40 p-6 lg:p-8 border border-zinc-800/80 rounded-3xl space-y-4\">\n        <h3 className=\"text-sm font-semibold tracking-wider font-mono text-zinc-300 uppercase\">\n          La Br\303\272jula de Decisiones de Sitiens\n        </h3>\n        <p className=\"text-zinc-400 text-sm font-light leading-relaxed max-w-4xl\">\n          Para deconstruir el inmovilismo social necesitamos diferenciar las justificaciones baratas de los dilemas \303\251ticos profundos. A continuaci\303\263n, diseccionamos las principales tesis y excusas que definen nuestra relaci\303\263n con los animales, agrupadas cient\303\255ficamente por su nivel de consenso, contradicci\303\263n f\303\241ctica o validez l\303\263gica.\n        </p>\n      </div>\n\n      {/* Filter Tabs layout */}\n      <div className=\"flex flex-wrap items-center gap-2 pt-2 border-b border-zinc-800/60 pb-4\">\n        <span className=\"text-xs font-mono text-zinc-500 mr-2 uppercase tracking-widest hidden sm:inline-block\">\n          Clasificaci\303\263n moral:\n        </span>\n        <button onClick={() => setSelectedCategory(\"ALL\")} className={getFilterButtonClass(\"ALL\")}>\n          Todos los Debates\n        </button>\n        <button onClick={() => setSelectedCategory(\"FALACIA\")} className={getFilterButtonClass(\"FALACIA\")}>\n          Falacias Refutadas\n        </button>\n        <button onClick={() => setSelectedCategory(\"DILEMA\")} className={getFilterButtonClass(\"DILEMA\")}>\n          Dilemas Filos\303\263ficos\n        </button>\n        <button onClick={() => setSelectedCategory(\"ESCENARIO_GRIS\")} className={getFilterButtonClass(\"ESCENARIO_GRIS\")}>\n          Escenarios Grises\n        </button>\n        <button onClick={() => setSelectedCategory(\"CONSENSO\")} className={getFilterButtonClass(\"CONSENSO\")}>\n          Consenso Absoluto\n        </button>\n      </div>\n\n      {/* List items with staggered reveal */}\n      <div className=\"space-y-4\">\n        <AnimatePresence mode=\"popLayout\">\n          {filteredDilemmas.map((d) => {\n            const isExpanded = expandedId === d.id;\n            const badge = getConsensusBadge(d.consensus);\n\n            return (\n              <motion.div\n                layout\n                key={d.id}\n                initial={{ opacity: 0, y: 12 }}\n                animate={{ opacity: 1, y: 0 }}\n                exit={{ opacity: 0, scale: 0.98 }}\n                transition={{ duration: 0.25 }}\n                className={`bg-zinc-900/35 border ${isExpanded ? \'border-zinc-700/80\' : \'border-zinc-800/80 hover:border-zinc-700/50\'} rounded-2xl overflow-hidden transition-all`}\n              >\n                {/* Header card area */}\n                <div \n                  onClick={() => setExpandedId(isExpanded ? null : d.id)}\n                  className=\"p-5 flex flex-col md:flex-row md:items-center justify-between gap-4 cursor-pointer select-none\"\n                >\n                  <div className=\"space-y-2 flex-1\">\n                    <div className=\"flex items-center gap-3\">\n                      <span className={`text-[10px] font-mono px-2 py-0.5 rounded flex items-center gap-1 ${badge?.classes}`}>\n                        {badge?.icon}\n                        {badge?.label}\n                      </span>\n                      <span className=\"text-[10px] uppercase font-mono text-zinc-650 bg-zinc-950/40 px-2 py-0.5 rounded\">\n                        Variable {d.category}\n                      </span>\n                    </div>\n                    <h3 className=\"text-lg font-bold text-white tracking-tight flex items-center gap-2\">\n                      {d.title}\n                    </h3>\n                    <p className=\"text-zinc-400 font-serif italic text-sm font-light leading-relaxed pl-3 border-l-2 border-zinc-800\">\n                      &ldquo;{d.popularStatement}&rdquo;\n                    </p>\n                  </div>\n\n                  <div className=\"flex items-center gap-3 self-end md:self-center\">\n                    {/* Ask to analyze button shortcut */}\n                    <button\n                      onClick={(e) => {\n                        e.stopPropagation();\n                        onSelectForAI(d.popularStatement);\n                      }}\n                      title=\"Test en el Validador de IA\"\n                      className=\"p-2 h-9 w-9 rounded-xl bg-zinc-950 text-zinc-500 hover:text-white hover:bg-zinc-800 border border-zinc-800 hover:border-zinc-700 transition-all flex items-center justify-center cursor-pointer\"\n                    >\n                      <Bot className=\"w-4 h-4\" />\n                    </button>\n                    \n                    <button className={`p-2 rounded-xl text-zinc-400 transition-transform ${isExpanded ? \'rotate-180 text-white\' : \'\'}`}>\n                      <ChevronDown className=\"w-5 h-5\" />\n                    </button>\n                  </div>\n                </div>\n\n                {/* Animated content expansion */}\n                <AnimatePresence>\n                  {isExpanded && (\n                    <motion.div\n                      initial={{ height: 0, opacity: 0 }}\n                      animate={{ height: \"auto\", opacity: 1 }}\n                      exit={{ height: 0, opacity: 0 }}\n                      transition={{ duration: 0.3, ease: \"easeInOut\" }}\n                    >\n                      <div className=\"px-5 pb-6 pt-2 border-t border-zinc-850 bg-zinc-950/20 grid grid-cols-1 md:grid-cols-12 gap-6 text-sm font-light\">\n                        {/* Science & data block */}\n                        <div className=\"md:col-span-6 space-y-2 bg-zinc-950/40 p-4 rounded-xl border border-zinc-850\">\n                          <h4 className=\"text-xs font-semibold tracking-wider font-mono text-zinc-350 uppercase flex items-center gap-1.5 border-b border-zinc-900 pb-1.5 mb-2\">\n                            <span className=\"w-1.5 h-1.5 rounded-full bg-blue-500\" />\n                            DISECCI\303\223N CIENT\303\215FICA\n                          </h4>\n                          <p className=\"text-zinc-450 leading-relaxed text-xs\">\n                            {d.scientificDeconstruction}\n                          </p>\n                        </div>\n\n                        {/* Philosophy & logic block */}\n                        <div className=\"md:col-span-6 space-y-2 bg-zinc-950/40 p-4 rounded-xl border border-zinc-850\">\n                          <h4 className=\"text-xs font-semibold tracking-wider font-mono text-zinc-350 uppercase flex items-center gap-1.5 border-b border-zinc-900 pb-1.5 mb-2\">\n                            <span className=\"w-1.5 h-1.5 rounded-full bg-amber-500\" />\n                            DEMOLICI\303\223N FILOS\303\223FICA\n                          </h4>\n                          <p className=\"text-zinc-450 leading-relaxed text-xs\">\n                            {d.philosophicalDeconstruction}\n                          </p>\n                        </div>\n\n                        {/* Socio-ecological impact bar */}\n                        <div className=\"md:col-span-12 space-y-1 mt-2 p-3.5 bg-zinc-950/10 rounded-xl border border-dotted border-zinc-800\">\n                          <span className=\"text-[10px] font-mono tracking-widest uppercase text-zinc-500 block\">\n                            Impacto en la Coexistencia:\n                          </span>\n                          <p className=\"text-xs text-zinc-400 italic\">\n                            {d.coexistenceImpact}\n                          </p>\n                        </div>\n                      </div>\n                    </motion.div>\n                  )}\n                </AnimatePresence>\n              </motion.div>\n            );\n          })}\n        </AnimatePresence>\n      </div>\n    </div>\n  );\n}\n"
    }
    diff {
      unified_diff {
