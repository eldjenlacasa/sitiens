          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const current = calculateFootprint(beef, pork, chicken, fish, dairy, eggs);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Plant-based equivalent footprint (roughly 90% savings across all items on average)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const plantEquivalent = {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    sufferingHours: 0,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    co2: parseFloat((current.co2 * 0.1).toFixed(1)),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    water: Math.round(current.water * 0.12),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    land: parseFloat((current.land * 0.08).toFixed(1))"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  };"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
