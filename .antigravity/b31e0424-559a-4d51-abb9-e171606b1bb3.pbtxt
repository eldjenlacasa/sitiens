  file_change {
    absolute_path_uri: "file:///src/components/ImpactCalculator.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \"react\";\nimport { \n  Flame, \n  Droplets, \n  Maximize, \n  Sparkles, \n  Trees, \n  Hourglass, \n  Frown, \n  Leaf, \n  HelpCircle \n} from \"lucide-react\";\nimport { motion } from \"motion/react\";\n\ninterface FootprintVals {\n  sufferingHours: number;\n  co2: number;\n  water: number;\n  land: number;\n}\n\nexport default function ImpactCalculator() {\n  const [beef, setBeef] = useState(200); // grams\n  const [pork, setPork] = useState(300); // grams\n  const [chicken, setChicken] = useState(400); // grams\n  const [fish, setFish] = useState(250); // grams\n  const [dairy, setDairy] = useState(2); // liters\n  const [eggs, setEggs] = useState(4); // units\n\n  const [reductionTarget, setReductionTarget] = useState<25 | 50 | 100>(50);\n\n  // Math coefficients per unit:\n  // Beef (100g): 18 suffering hours, 6.0kg CO2, 1500L water, 32m2 land\n  // Pork (100g): 15 suffering hours, 1.2kg CO2, 600L water, 3.2m2 land\n  // Chicken (100g): 32 suffering hours, 0.7kg CO2, 400L water, 1.5m2 land (high stress density)\n  // Fish (100g): 24 suffering hours, 0.5kg CO2, 120L water, 0.2m2 land\n  // Dairy (1 Liter): 50 suffering hours, 2.0kg CO2, 1000L water, 4.5m2 land\n  // Eggs (1 unit): 72 suffering hours, 0.3kg CO2, 200L water, 0.6m2 land (includes cull of male chicks)\n\n  const calculateFootprint = (\n    b: number, \n    pk: number, \n    ch: number, \n    f: number, \n    d: number, \n    e: number\n  ): FootprintVals => {\n    const beefMult = b / 100;\n    const porkMult = pk / 100;\n    const chickenMult = ch / 100;\n    const fishMult = f / 105;\n\n    const suffering = \n      (beefMult * 18) + \n      (porkMult * 15) + \n      (chickenMult * 32) + \n      (fishMult * 24) + \n      (d * 50) + \n      (e * 72);\n\n    const co2 = \n      (beefMult * 6.0) + \n      (porkMult * 1.2) + \n      (chickenMult * 0.7) + \n      (fishMult * 0.5) + \n      (d * 2.0) + \n      (e * 0.3);\n\n    const water = \n      (beefMult * 1500) + \n      (porkMult * 600) + \n      (chickenMult * 400) + \n      (fishMult * 120) + \n      (d * 1000) + \n      (e * 200);\n\n    const land = \n      (beefMult * 32) + \n      (porkMult * 3.2) + \n      (chickenMult * 1.5) + \n      (fishMult * 0.2) + \n      (d * 4.5) + \n      (e * 0.6);\n\n    return {\n      sufferingHours: Math.round(suffering),\n      co2: parseFloat(co2.toFixed(1)),\n      water: Math.round(water),\n      land: parseFloat(land.toFixed(1))\n    };\n  };\n\n  const current = calculateFootprint(beef, pork, chicken, fish, dairy, eggs);\n\n  // Plant-based equivalent footprint (roughly 90% savings across all items on average)\n  const plantEquivalent = {\n    sufferingHours: 0,\n    co2: parseFloat((current.co2 * 0.1).toFixed(1)),\n    water: Math.round(current.water * 0.12),\n    land: parseFloat((current.land * 0.08).toFixed(1))\n  };\n\n  // Reduction savings\n  const savedHours = Math.round(current.sufferingHours * (reductionTarget / 100));\n  const savedCo2 = parseFloat((current.co2 * (reductionTarget / 100)).toFixed(1));\n  const savedWater = Math.round(current.water * (reductionTarget / 100));\n  const savedLand = parseFloat((current.land * (reductionTarget / 100)).toFixed(1));\n\n  // Equivalencies:\n  // - 1 shower = 60 Liters\n  // - 1 Tree stores ~22kg of CO2 per year\n  // - 1 m2 land = Area preserved\n  const equivalentShowers = Math.round(savedWater / 60);\n  const equivalentTrees = parseFloat((savedCo2 / (22 / 52)).toFixed(1)); // tree/week equivalents\n\n  return (\n    <div id=\"impact-calculator-view\" className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch w-full max-w-6xl mx-auto\">\n      {/* Parameters Panel */}\n      <div className=\"lg:col-span-6 p-6 lg:p-8 bg-zinc-950/30 border border-zinc-800/80 rounded-3xl flex flex-col justify-between space-y-6\">\n        <div>\n          <h3 className=\"text-sm font-semibold tracking-wider font-mono text-zinc-300 uppercase mb-2 flex items-center gap-1.5\">\n            <Sparkles className=\"w-4 h-4 text-amber-500\" />\n            Par\303\241metros de Ingesta Semanal\n          </h3>\n          <p className=\"text-xs text-zinc-500 font-light leading-relaxed mb-6\">\n            Ajusta los deslizadores seg\303\272n tu ingesta de alimentos f\303\241cticos semanales para calcular su peso termodin\303\241mico, h\303\255drico y moral.\n          </p>\n\n          <div className=\"space-y-5\">\n            {/* Beef slider */}\n            <div className=\"space-y-1.5\">\n              <div className=\"flex justify-between text-xs\">\n                <span className=\"text-zinc-300 font-medium\">Vacuno / Ternera</span>\n                <span className=\"font-mono text-zinc-400 font-bold\">{beef} g</span>\n              </div>\n              <input \n                type=\"range\" \n                min=\"0\" \n                max=\"1000\" \n                step=\"50\"\n                value={beef} \n                onChange={(e) => setBeef(parseInt(e.target.value))}\n                className=\"w-full accent-red-500 bg-zinc-900 h-1 rounded-lg cursor-pointer\"\n              />\n            </div>\n\n            {/* Pork slider */}\n            <div className=\"space-y-1.5\">\n              <div className=\"flex justify-between text-xs\">\n                <span className=\"text-zinc-300 font-medium\">Cerdo / Embutidos</span>\n                <span className=\"font-mono text-zinc-400 font-bold\">{pork} g</span>\n              </div>\n              <input \n                type=\"range\" \n                min=\"0\" \n                max=\"1000\" \n                step=\"50\"\n                value={pork} \n                onChange={(e) => setPork(parseInt(e.target.value))}\n                className=\"w-full accent-orange-500 bg-zinc-900 h-1 rounded-lg cursor-pointer\"\n              />\n            </div>\n\n            {/* Chicken slider */}\n            <div className=\"space-y-1.5\">\n              <div className=\"flex justify-between text-xs\">\n                <span className=\"text-zinc-300 font-medium\">Aves / Pollo</span>\n                <span className=\"font-mono text-zinc-400 font-bold\">{chicken} g</span>\n              </div>\n              <input \n                type=\"range\" \n                min=\"0\" \n                max=\"1200\" \n                step=\"50\"\n                value={chicken} \n                onChange={(e) => setChicken(parseInt(e.target.value))}\n                className=\"w-full accent-yellow-500 bg-zinc-900 h-1 rounded-lg cursor-pointer\"\n              />\n            </div>\n\n            {/* Fish slider */}\n            <div className=\"space-y-1.5\">\n              <div className=\"flex justify-between text-xs\">\n                <span className=\"text-zinc-300 font-medium\">Pescado y Mariscos</span>\n                <span className=\"font-mono text-zinc-400 font-bold\">{fish} g</span>\n              </div>\n              <input \n                type=\"range\" \n                min=\"0\" \n                max=\"1000\" \n                step=\"50\"\n                value={fish} \n                onChange={(e) => setFish(parseInt(e.target.value))}\n                className=\"w-full accent-blue-500 bg-zinc-900 h-1 rounded-lg cursor-pointer\"\n              />\n            </div>\n\n            {/* Dairy slider */}\n            <div className=\"space-y-1.5\">\n              <div className=\"flex justify-between text-xs\">\n                <span className=\"text-zinc-300 font-medium font-sans\">L\303\241cteos (Leche, Quesos)</span>\n                <span className=\"font-mono text-zinc-400 font-bold\">{dairy} L</span>\n              </div>\n              <input \n                type=\"range\" \n                min=\"0\" \n                max=\"8\" \n                step=\"0.5\"\n                value={dairy} \n                onChange={(e) => setDairy(parseFloat(e.target.value))}\n                className=\"w-full accent-indigo-500 bg-zinc-900 h-1 rounded-lg cursor-pointer\"\n              />\n            </div>\n\n            {/* Eggs slider */}\n            <div className=\"space-y-1.5\">\n              <div className=\"flex justify-between text-xs\">\n                <span className=\"text-zinc-300 font-medium\">Huevos</span>\n                <span className=\"font-mono text-zinc-400 font-bold\">{eggs} unidades</span>\n              </div>\n              <input \n                type=\"range\" \n                min=\"0\" \n                max=\"24\" \n                step=\"1\"\n                value={eggs} \n                onChange={(e) => setEggs(parseInt(e.target.value))}\n                className=\"w-full accent-purple-500 bg-zinc-900 h-1 rounded-lg cursor-pointer\"\n              />\n            </div>\n          </div>\n        </div>\n\n        {/* Dynamic Methodology Footnote */}\n        <div className=\"bg-zinc-950/50 p-4 border border-zinc-900 rounded-2xl space-y-1\">\n          <span className=\"text-[10px] font-mono tracking-wider text-zinc-500 block flex items-center gap-1\">\n            <HelpCircle className=\"w-3 h-3\" /> NOTE DE RIGOR MATEM\303\201TICO:\n          </span>\n          <p className=\"text-[10.5px] text-zinc-455 font-light leading-normal\">\n            La <strong className=\"text-zinc-300\">Constante de Sufrimiento</strong> calcula las horas reales de hacinamiento y confinamiento intensivo exigidas para obtener esa remesa de gramos, dividiendo la esperanza de vida del animal en granja por su rendimiento de canal cal\303\263rica final en gramaje biol\303\263gico f\303\241ctico.\n          </p>\n        </div>\n      </div>\n\n      {/* Visual Analytics Output Panel */}\n      <div className=\"lg:col-span-6 p-6 lg:p-8 border border-zinc-800/80 rounded-3xl bg-zinc-900/10 flex flex-col justify-between space-y-8\">\n        <div>\n          <h3 className=\"text-sm font-semibold tracking-wider font-mono text-zinc-300 uppercase mb-4\">\n            An\303\241lisis de Impacto Colectivo (Semanal)\n          </h3>\n\n          <div className=\"grid grid-cols-2 gap-4\">\n            {/* Metric A: Suffering */}\n            <div className=\"bg-zinc-950/40 p-4 border border-zinc-850 rounded-2xl flex flex-col justify-between\">\n              <div className=\"flex items-center justify-between mb-2\">\n                <span className=\"text-[10px] font-mono tracking-widest text-zinc-500 uppercase\">SUFRIMIENTO</span>\n                <Hourglass className=\"w-4 h-4 text-red-500\" />\n              </div>\n              <div className=\"space-y-0.5\">\n                <span className=\"text-2xl font-black text-white font-mono tracking-tight\">{current.sufferingHours} h</span>\n                <p className=\"text-[10px] text-zinc-500 leading-tight\">De confinamiento sist\303\251mico patrocinado.</p>\n              </div>\n            </div>\n\n            {/* Metric B: CO2 */}\n            <div className=\"bg-zinc-950/40 p-4 border border-zinc-850 rounded-2xl flex flex-col justify-between\">\n              <div className=\"flex items-center justify-between mb-2\">\n                <span className=\"text-[10px] font-mono tracking-widest text-zinc-500 uppercase\">CALENTAMIENTO</span>\n                <Flame className=\"w-4 h-4 text-orange-500\" />\n              </div>\n              <div className=\"space-y-0.5\">\n                <span className=\"text-2xl font-black text-white font-mono tracking-tight\">{current.co2} kg</span>\n                <p className=\"text-[10px] text-zinc-500 leading-tight\">Gases de efecto invernadero (CO2-eq) liberados.</p>\n              </div>\n            </div>\n\n            {/* Metric C: Water */}\n            <div className=\"bg-zinc-950/40 p-4 border border-zinc-850 rounded-2xl flex flex-col justify-between\">\n              <div className=\"flex items-center justify-between mb-2\">\n                <span className=\"text-[10px] font-mono tracking-widest text-zinc-500 uppercase\">RECURSO H\303\215DRICO</span>\n                <Droplets className=\"w-4 h-4 text-indigo-400\" />\n              </div>\n              <div className=\"space-y-0.5\">\n                <span className=\"text-2xl font-black text-white font-mono tracking-tight\">{current.water.toLocaleString()} L</span>\n                <p className=\"text-[10px] text-zinc-500 leading-tight\">Agua dulce consumida en el ciclo vital.</p>\n              </div>\n            </div>\n\n            {/* Metric D: Land */}\n            <div className=\"bg-zinc-950/40 p-4 border border-zinc-850 rounded-2xl flex flex-col justify-between\">\n              <div className=\"flex items-center justify-between mb-2\">\n                <span className=\"text-[10px] font-mono tracking-widest text-zinc-500 uppercase\">TERRITORIO</span>\n                <Maximize className=\"w-4 h-4 text-emerald-400\" />\n              </div>\n              <div className=\"space-y-0.5\">\n                <span className=\"text-2xl font-black text-white font-mono tracking-tight\">{current.land} m\302\262</span>\n                <p className=\"text-[10px] text-zinc-500 leading-tight\">\303\201rea terrestre o forrajera asediada.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Sliding Target of reduction */}\n        <div className=\"pt-4 border-t border-zinc-850 space-y-4\">\n          <div className=\"flex items-center justify-between flex-wrap gap-2\">\n            <span className=\"text-xs font-mono text-zinc-400 uppercase tracking-widest\">\n              SIMULAR REDUCCI\303\223N SEMANAL SITIENS:\n            </span>\n            <div className=\"flex gap-1.5 bg-zinc-950/50 p-1 rounded-xl border border-zinc-850\">\n              <button \n                onClick={() => setReductionTarget(25)}\n                className={`px-2.5 py-1 text-[10px] font-mono rounded-lg transition-all cursor-pointer ${reductionTarget === 25 ? \'bg-zinc-800 text-white border border-zinc-700\' : \'text-zinc-500 hover:text-zinc-300\'}`}\n              >\n                25%\n              </button>\n              <button \n                onClick={() => setReductionTarget(50)}\n                className={`px-2.5 py-1 text-[10px] font-mono rounded-lg transition-all cursor-pointer ${reductionTarget === 50 ? \'bg-zinc-800 text-white border border-zinc-700\' : \'text-zinc-500 hover:text-zinc-300\'}`}\n              >\n                50%\n              </button>\n              <button \n                onClick={() => setReductionTarget(100)}\n                className={`px-2.5 py-1 text-[10px] font-mono rounded-lg transition-all cursor-pointer ${reductionTarget === 100 ? \'bg-emerald-500/20 text-emerald-300 border border-emerald-500/40\' : \'text-zinc-500 hover:text-zinc-300\'}`}\n              >\n                100% (Veg)\n              </button>\n            </div>\n          </div>\n\n          {/* Actionable results of reduction */}\n          <div className=\"bg-zinc-950/40 border border-zinc-850 rounded-2xl p-5 space-y-4 relative overflow-hidden\">\n            <div className=\"absolute right-3 top-3 h-12 w-12 text-emerald-500/10 pointer-events-none\">\n              <Leaf className=\"w-full h-full\" />\n            </div>\n\n            <h4 className=\"text-xs font-mono tracking-widest text-emerald-400 font-bold flex items-center gap-1.5\">\n              AHORRO AL CONSEGUIR EL OBJETIVO DEL {reductionTarget}%:\n            </h4>\n\n            <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4 text-xs font-light\">\n              <div className=\"space-y-1\">\n                <div className=\"flex items-center gap-1.5 text-zinc-300\">\n                  <Frown className=\"w-3.5 h-3.5 text-red-400\" />\n                  <span>Sufrimiento evitado:</span>\n                </div>\n                <div className=\"text-base font-bold font-mono text-zinc-100\">{savedHours} horas/semana</div>\n              </div>\n\n              <div className=\"space-y-1\">\n                <div className=\"flex items-center gap-1.5 text-zinc-300\">\n                  <Droplets className=\"w-3.5 h-3.5 text-blue-400\" />\n                  <span>Agua regenerada:</span>\n                </div>\n                <div className=\"text-base font-bold font-mono text-zinc-100\">{savedWater.toLocaleString()} litros</div>\n                <p className=\"text-[9.5px] text-zinc-500 font-mono\">\342\211\210 {equivalentShowers} duchas familiares salvadas</p>\n              </div>\n\n              <div className=\"space-y-1\">\n                <div className=\"flex items-center gap-1.5 text-zinc-300\">\n                  <Trees className=\"w-3.5 h-3.5 text-emerald-400\" />\n                  <span>CO\342\202\202 evitado:</span>\n                </div>\n                <div className=\"text-base font-bold font-mono text-zinc-100\">{savedCo2} kg de CO\342\202\202-eq</div>\n                <p className=\"text-[9.5px] text-zinc-500 font-mono\">\342\211\210 Captura semanal de {equivalentTrees} \303\241rboles adultos</p>\n              </div>\n\n              <div className=\"space-y-1\">\n                <div className=\"flex items-center gap-1.5 text-zinc-300\">\n                  <Maximize className=\"w-3.5 h-3.5 text-pink-400\" />\n                  <span>Suelo no invadido:</span>\n                </div>\n                <div className=\"text-base font-bold font-mono text-zinc-100\">{savedLand} m\302\262 anualizados/semana</div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
