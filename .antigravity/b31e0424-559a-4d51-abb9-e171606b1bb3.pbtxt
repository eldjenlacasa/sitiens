  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \"react\";\nimport { \n  Network, \n  Layers, \n  Calculator, \n  BrainCircuit, \n  Compass, \n  ExternalLink,\n  Github,\n  BookOpen,\n  ArrowRight,\n  Sparkles,\n  Award,\n  HelpCircle\n} from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\n// Sub-components\nimport NetworkGraph from \"./components/NetworkGraph\";\nimport ExcusesDilemmas from \"./components/ExcusesDilemmas\";\nimport ImpactCalculator from \"./components/ImpactCalculator\";\nimport AiValidator from \"./components/AiValidator\";\n\ntype AppView = \"home\" | \"graph\" | \"dilemmas\" | \"calculator\" | \"validator\";\n\nexport default function App() {\n  const [currentView, setCurrentView] = useState<AppView>(\"home\");\n  const [selectedArgumentForAI, setSelectedArgumentForAI] = useState<string | null>(null);\n\n  // Variables list displayed on the front page (the 4 cards)\n  const focalAreas = [\n    {\n      num: \"01\",\n      title: \"SINTIENCIA\",\n      subtitle: \"La Variable Biol\303\263gica\",\n      desc: \"La frontera biol\303\263gica entre la conciencia y la reacci\303\263n autom\303\241tica del reino vegetal. An\303\241lisis de la nocicepci\303\263n animal y la encefalizaci\303\263n.\",\n      color: \"border-red-500/20 hover:border-red-500/50 bg-red-500/[0.02]\",\n      badge: \"Red-based Nociception\",\n    },\n    {\n      num: \"02\",\n      title: \"HISTORIA\",\n      subtitle: \"La Variable Evolutiva\",\n      desc: \"El motor de nuestra especie. C\303\263mo los animales sirvieron como herramientas fundamentales e infraestructura viva para consolidar el Neol\303\255tico.\",\n      color: \"border-blue-500/20 hover:border-blue-500/50 bg-blue-500/[0.02]\",\n      badge: \"Estructura Antr\303\263pica\",\n    },\n    {\n      num: \"03\",\n      title: \"CLIMA\",\n      subtitle: \"La Variable F\303\255sica\",\n      desc: \"Termodin\303\241mica del da\303\261o. An\303\241lisis de emisiones de metano, deforestaci\303\263n, ineficiencia cal\303\263rica y colapso de sumideros h\303\255dricos globales.\",\n      color: \"border-emerald-500/20 hover:border-emerald-500/50 bg-emerald-500/[0.02]\",\n      badge: \"Carga Termodin\303\241mica\",\n    },\n    {\n      num: \"04\",\n      title: \"ELECCI\303\223N\",\n      subtitle: \"La Variable Moral\",\n      desc: \"Placer, disonancia y el poder del progreso biol\303\263gico de la suplementaci\303\263n que nos independiza moralmente de la depredaci\303\263n obligatoria.\",\n      color: \"border-amber-500/20 hover:border-amber-500/50 bg-amber-500/[0.02]\",\n      badge: \"Axiomas de Elecci\303\263n\",\n    }\n  ];\n\n  const handleShortcutToAI = (text: string) => {\n    setSelectedArgumentForAI(text);\n    setCurrentView(\"validator\");\n  };\n\n  return (\n    <div className=\"min-h-screen bg-[#070709] text-zinc-100 flex flex-col font-sans selection:bg-zinc-800 selection:text-white\">\n      \n      {/* Premium top Navigation bar */}\n      <header className=\"border-b border-zinc-900/80 bg-zinc-950/60 backdrop-blur-2xl px-6 py-4 sticky top-0 z-50 transition-all\">\n        <div className=\"max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4\">\n          \n          {/* Logo brand */}\n          <div className=\"flex items-center gap-3\">\n            <div className=\"h-9 w-9 rounded-xl bg-zinc-900 border border-zinc-800 flex items-center justify-center font-mono font-bold text-white tracking-wider glow-soft text-sm\">\n              S\n            </div>\n            <div className=\"flex flex-col\">\n              <span className=\"text-base font-extrabold tracking-tight text-white font-mono leading-none\">\n                Sitiens\n              </span>\n              <span className=\"text-[9.5px] font-mono text-zinc-500 tracking-widest mt-0.5\">\n                CRITICISM & BIOETHICS\n              </span>\n            </div>\n          </div>\n\n          {/* Nav Links in tabs selector styled like tabs inside container */}\n          <nav className=\"flex flex-wrap items-center bg-zinc-950/80 p-1 border border-zinc-800/80 rounded-2xl w-full md:w-auto overflow-x-auto justify-center\">\n            <button\n              onClick={() => setCurrentView(\"home\")}\n              className={`px-4 py-2 text-xs font-mono rounded-xl transition-all cursor-pointer ${\n                currentView === \"home\" ? \"bg-zinc-900 text-white border border-zinc-800\" : \"text-zinc-500 hover:text-zinc-300\"\n              }`}\n            >\n              00. Inicio\n            </button>\n            <button\n              onClick={() => setCurrentView(\"graph\")}\n              className={`px-4 py-2 text-xs font-mono rounded-xl transition-all cursor-pointer flex items-center gap-1.5 ${\n                currentView === \"graph\" ? \"bg-zinc-900 text-white border border-zinc-800\" : \"text-zinc-500 hover:text-zinc-300\"\n              }`}\n            >\n              <Network className=\"w-3.5 h-3.5\" />\n              01. Red de Conocimiento\n            </button>\n            <button\n              onClick={() => setCurrentView(\"dilemmas\")}\n              className={`px-4 py-2 text-xs font-mono rounded-xl transition-all cursor-pointer flex items-center gap-1.5 ${\n                currentView === \"dilemmas\" ? \"bg-zinc-900 text-white border border-zinc-800\" : \"text-zinc-500 hover:text-zinc-300\"\n              }`}\n            >\n              <Layers className=\"w-3.5 h-3.5\" />\n              02. Dilemas y Falacias\n            </button>\n            <button\n              onClick={() => setCurrentView(\"calculator\")}\n              className={`px-4 py-2 text-xs font-mono rounded-xl transition-all cursor-pointer flex items-center gap-1.5 ${\n                currentView === \"calculator\" ? \"bg-zinc-900 text-white border border-zinc-800\" : \"text-zinc-500 hover:text-zinc-300\"\n              }`}\n            >\n              <Calculator className=\"w-3.5 h-3.5\" />\n              03. Calculadora\n            </button>\n            <button\n              onClick={() => setCurrentView(\"validator\")}\n              className={`px-4 py-2 text-xs font-mono rounded-xl transition-all cursor-pointer flex items-center gap-1.5 ${\n                currentView === \"validator\" ? \"bg-zinc-900 text-white border border-zinc-800\" : \"text-zinc-500 hover:text-zinc-300\"\n              }`}\n            >\n              <BrainCircuit className=\"w-3.5 h-3.5\" />\n              04. Validador de Argumentos\n            </button>\n          </nav>\n\n        </div>\n      </header>\n\n      {/* Main Workspace Frame container */}\n      <main className=\"flex-1 max-w-6xl w-full mx-auto p-4 md:p-6 lg:p-8 flex flex-col justify-start\">\n        <AnimatePresence mode=\"wait\">\n          \n          {/* TAB 1: HOME */}\n          {currentView === \"home\" && (\n            <motion.div\n              layoutId=\"home-tab\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.35, ease: \"easeOut\" }}\n              className=\"space-y-12\"\n            >\n              {/* Giant Socratic Hero section */}\n              <div className=\"py-4 md:py-12 text-center space-y-6 max-w-4xl mx-auto\">\n                <div className=\"inline-flex gap-1.5 items-center px-4 py-1.5 rounded-full bg-zinc-950/40 border border-zinc-800 text-[10.5px] tracking-widest font-mono text-zinc-500 uppercase\">\n                  <span className=\"w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse\" />\n                  DISE\303\221O Y ARQUITECTURA DE INFORMACI\303\223N \303\211TICA\n                </div>\n\n                <h1 className=\"text-5xl md:text-7xl font-extrabold tracking-tight text-white leading-none\">\n                  \302\277Qu\303\251 vidas importan?\n                </h1>\n\n                <p className=\"text-lg md:text-2xl text-zinc-400 font-light leading-relaxed max-w-2xl mx-auto\">\n                  Un an\303\241lisis cr\303\255tico sobre nuestra relaci\303\263n con los animales y los axiomas que la definen.\n                </p>\n\n                {/* Main Action trigger buttons */}\n                <div className=\"pt-6 flex flex-wrap justify-center gap-4\">\n                  <button \n                    onClick={() => setCurrentView(\"graph\")}\n                    className=\"px-6 py-3 rounded-full bg-zinc-100 hover:bg-zinc-200 text-zinc-950 font-bold text-xs font-mono tracking-wide flex items-center gap-2 transition-all shadow-md cursor-pointer\"\n                  >\n                    <span>01. Explorar el Grafo</span>\n                    <ArrowRight className=\"w-3.5 h-3.5\" />\n                  </button>\n                  <button \n                    onClick={() => setCurrentView(\"validator\")}\n                    className=\"px-6 py-3 rounded-full bg-zinc-900 hover:bg-zinc-800 text-zinc-300 font-medium text-xs font-mono tracking-wide border border-zinc-800 hover:border-zinc-700 flex items-center gap-2 transition-all cursor-pointer\"\n                  >\n                     <span>Descomprimir Excusas con IA</span>\n                  </button>\n                </div>\n              </div>\n\n              {/* Dynamic Socratic Mirror intro */}\n              <div className=\"grid grid-cols-1 md:grid-cols-12 gap-8 items-center bg-zinc-950/40 border border-zinc-900 rounded-3xl p-6 md:p-8\">\n                <div className=\"md:col-span-8 space-y-4\">\n                  <h3 className=\"text-sm font-semibold tracking-wider font-mono text-zinc-300 uppercase\">\n                     EL OBJETIVO DE SITIENS\n                  </h3>\n                  <p className=\"text-zinc-400 text-sm font-light leading-relaxed\">\n                     Esta plataforma no busca darte respuestas prefabricadas sobre vegetarianismo o dictar dogmas morales. Sitiens utiliza un <strong className=\"text-zinc-300\">enfoque socr\303\241tico e inform\303\241tico</strong> para ayudarte a mapear con rigor cient\303\255fico la historia, la biolog\303\255a nuclear del sufrimiento y el colapso del ecosistema actual. El objetivo es desarmar las contradicciones l\303\263gicas (como la disonancia cognitiva que aplicamos con las mascotas) hasta que sientas la sincera incomodidad existencial que impulsa tu propio pensamiento cr\303\255tico.\n                  </p>\n                </div>\n                <div className=\"md:col-span-4 p-5 bg-zinc-900/10 border border-dashed border-zinc-800 rounded-2xl flex flex-col justify-between space-y-4 font-mono text-[10.5px]\">\n                  <div className=\"flex items-center gap-2 text-zinc-400 font-bold\">\n                    <Compass className=\"w-4 h-4 text-zinc-500\" />\n                    <span>COMO NAVEGAR POR EL HUB:</span>\n                  </div>\n                  <ul className=\"space-y-1.5 text-zinc-500 font-light\">\n                    <li>\342\200\242 El <strong className=\"text-zinc-400\">Grafo</strong> desmonta la rigidez secuencial de los debates.</li>\n                    <li>\342\200\242 Las <strong className=\"text-zinc-400\">Falacias</strong> separan pretextos de dilemas l\303\263gicos reales.</li>\n                    <li>\342\200\242 La <strong className=\"text-zinc-400\">Calculadora</strong> calcula el sufrimiento e impacto de tus decisiones.</li>\n                  </ul>\n                </div>\n              </div>\n\n              {/* Grid of the 4 variables cards */}\n              <div className=\"space-y-4\">\n                <div className=\"text-center md:text-left space-y-1\">\n                  <span className=\"text-[10px] font-mono tracking-widest text-zinc-500 uppercase block\">\n                    LOS CUATRO PILARES ESTRUCTURALES SITIENS\n                  </span>\n                  <h2 className=\"text-2xl font-bold text-white tracking-tight\">Las Variables de Coexistencia</h2>\n                </div>\n\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\">\n                  {focalAreas.map((area, index) => (\n                    <div\n                      key={index}\n                      className={`p-6 border rounded-2xl flex flex-col justify-between space-y-4 hover:scale-[1.01] transition-all duration-300 ${area.color}`}\n                    >\n                      <div className=\"space-y-2\">\n                        <span className=\"text-[10.5px] font-mono text-zinc-500 block\">[{area.num}]</span>\n                        <div className=\"space-y-0.5\">\n                          <h3 className=\"text-sm font-bold tracking-wider text-zinc-300 font-mono uppercase\">{area.title}</h3>\n                          <span className=\"text-xs text-zinc-400 tracking-tight font-serif italic block\">{area.subtitle}</span>\n                        </div>\n                        <p className=\"text-xs text-zinc-500 leading-relaxed font-light font-sans pt-1.5\">\n                          {area.desc}\n                        </p>\n                      </div>\n\n                      <div className=\"flex items-center justify-between pt-2 border-t border-zinc-900\">\n                        <span className=\"text-[9.5px] font-mono text-zinc-650 tracking-wider\">\n                          {area.badge}\n                        </span>\n                        <button \n                          onClick={() => setCurrentView(\"graph\")}\n                          className=\"p-1.5 rounded-lg bg-zinc-900/50 hover:bg-zinc-800 text-zinc-500 hover:text-zinc-300 transition-all cursor-pointer\"\n                        >\n                          <ArrowRight className=\"w-3.5 h-3.5\" />\n                        </button>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              </div>\n\n            </motion.div>\n          )}\n\n          {/* TAB 2: NETWORK GRAPH */}\n          {currentView === \"graph\" && (\n            <motion.div\n              layoutId=\"graph-tab\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.3 }}\n              className=\"w-full\"\n            >\n              <NetworkGraph />\n            </motion.div>\n          )}\n\n          {/* TAB 3: POPULAR DILEMMAS & CRITIQUES */}\n          {currentView === \"dilemmas\" && (\n            <motion.div\n              layoutId=\"dilemmas-tab\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.3 }}\n              className=\"w-full\"\n            >\n              <ExcusesDilemmas onSelectForAI={handleShortcutToAI} />\n            </motion.div>\n          )}\n\n          {/* TAB 4: ACCURACY CALCULATOR */}\n          {currentView === \"calculator\" && (\n            <motion.div\n              layoutId=\"calc-tab\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.3 }}\n              className=\"w-full\"\n            >\n              <ImpactCalculator />\n            </motion.div>\n          )}\n\n          {/* TAB 5: AI VALIDATOR */}\n          {currentView === \"validator\" && (\n            <motion.div\n              layoutId=\"val-tab\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.3 }}\n              className=\"w-full\"\n            >\n              <AiValidator \n                argumentToAnalyze={selectedArgumentForAI} \n                clearArgument={() => setSelectedArgumentForAI(null)} \n              />\n            </motion.div>\n          )}\n\n        </AnimatePresence>\n      </main>\n\n      {/* Platform minimal footer */}\n      <footer className=\"border-t border-zinc-900/80 bg-zinc-950/40 py-6 px-6 mt-16 font-mono text-[10px] text-zinc-500\">\n        <div className=\"max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4\">\n          <div className=\"flex items-center gap-2\">\n            <span>\302\251 2026 SITIENS PROJECT.</span>\n            <span className=\"text-zinc-750\">|</span>\n            <span className=\"text-zinc-450 hover:text-zinc-300 transition-all flex items-center gap-1\">\n              Desarrollado para Germ\303\241n\n            </span>\n          </div>\n          <div className=\"flex items-center gap-4\">\n            <span className=\"hover:text-zinc-300 transition-all select-none\">\n              v1.0.0\n            </span>\n          </div>\n        </div>\n      </footer>\n\n    </div>\n  );\n}\n"
    }
