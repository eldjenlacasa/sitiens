      replacement_content: "import { useState, useEffect } from \"react\";\nimport { \n  Send, \n  HelpCircle, \n  AlertCircle, \n  PlusCircle, \n  Loader2, \n  Compass, \n  Brain, \n  FileText, \n  ShieldAlert, \n  Workflow, \n  Activity, \n  CheckCircle2, \n  Flame, \n  Sparkles \n} from \"lucide-react\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\ninterface AIAnalysisResult {\n  argumentSummary: string;\n  axioms: string[];\n  scientificAccuracy: {\n    rating: string;\n    analysis: string;\n  };\n  logicalFailures: string[];\n  impactAnalysis: {\n    sintiente: string;\n    ecosistemic: string;\n  };\n  alternativeReflection: string;\n}\n\ninterface AiValidatorProps {\n  argumentToAnalyze: string | null;\n  clearArgument: () => void;\n}\n\nconst PRESET_EXCUSAS = [\n  \"Los seres humanos somos omn\303\255voros por evoluci\303\263n f\303\241ctica.\",\n  \"La ganader\303\255a extensiva respeta el bienestar animal y no da\303\261a nada.\",\n  \"Comer carne estimula la econom\303\255a, da empleo y mantiene tradiciones m\303\255sticas.\",\n  \"Si dejamos de comer animales, se reproducir\303\255an sin control y extinguir\303\255an los pastos.\"\n];\n\nexport default function AiValidator({ argumentToAnalyze, clearArgument }: AiValidatorProps) {\n  const [userInput, setUserInput] = useState(\"\");\n  const [analysis, setAnalysis] = useState<AIAnalysisResult | null>(null);\n  const [loading, setLoading] = useState(false);\n  const [error, setError] = useState<string | null>(null);\n\n  useEffect(() => {\n    if (argumentToAnalyze) {\n      setUserInput(argumentToAnalyze);\n      handleOnSubmit(argumentToAnalyze);\n      clearArgument(); // reset trigger on parent\n    }\n  }, [argumentToAnalyze]);\n\n  const handleOnSubmit = async (textToSend: string) => {\n    const finalVal = textToSend || userInput;\n    if (!finalVal.trim()) return;\n\n    setLoading(true);\n    setError(null);\n    setAnalysis(null);\n\n    try {\n      const response = await fetch(\"/api/analyze-argument\", {\n        method: \"POST\",\n        headers: { \"Content-Type\": \"application/json\" },\n        body: JSON.stringify({ argument: finalVal, context: \"Sitiens AI Validator\" })\n      });\n\n      if (!response.ok) {\n        throw new Error(\"El servidor no pudo procesar la solicitud de an\303\241lisis. Comprueba la API key o reint\303\251ntalo.\");\n      }\n\n      const data = await response.json();\n      if (data.error) {\n        throw new Error(data.error);\n      }\n      setAnalysis(data);\n    } catch (err: any) {\n      console.error(err);\n      setError(err?.message || \"Algo sali\303\263 mal procesando el an\303\241lisis.\");\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  return (\n    <div id=\"ai-validator-view\" className=\"space-y-8 w-full max-w-6xl mx-auto\">\n      {/* Intro section */}\n      <div className=\"bg-zinc-950/40 p-6 lg:p-8 border border-zinc-800/80 rounded-3xl grid grid-cols-1 md:grid-cols-12 gap-6 items-center\">\n        <div className=\"md:col-span-8 space-y-3\">\n          <h3 className=\"text-sm font-semibold tracking-wider font-mono text-zinc-300 uppercase flex items-center gap-1.5\">\n            <Brain className=\"w-4 h-4 text-purple-400\" />\n            Descompresor de Axiomas No Examinados\n          </h3>\n          <p className=\"text-zinc-400 text-sm font-light leading-relaxed\">\n            Escribe cualquier argumento, justificaci\303\263n, dogma o excusa que utilices (o escuches) para continuar consumiendo animales. La Inteligencia Artificial Sitiens, equipada con datos emp\303\255ricos de neurobiolog\303\255a, termodin\303\241mica y bio\303\251tica laica, deconstruir\303\241 cr\303\255ticamente su validez l\303\263gica y expondr\303\241 sus sesgos de forma socr\303\241tica.\n          </p>\n        </div>\n        <div className=\"md:col-span-4 flex flex-wrap gap-2 justify-end\">\n          <span className=\"text-[10px] font-mono text-zinc-500 bg-zinc-900 border border-zinc-800 px-3 py-1.5 rounded-xl\">\n             Modo: Dial\303\251ctica Cl\303\255nica\n          </span>\n        </div>\n      </div>\n\n      {/* Input Form Panel */}\n      <div className=\"bg-zinc-900/10 backdrop-blur-md border border-zinc-800/80 p-5 lg:p-6 rounded-3xl space-y-4\">\n        <div className=\"flex gap-2\">\n          <input\n            type=\"text\"\n            value={userInput}\n            onChange={(e) => setUserInput(e.target.value)}\n            onKeyDown={(e) => { if (e.key === \"Enter\") handleOnSubmit(\"\"); }}\n            placeholder=\"Introduce una excusa: ej. \'Los leones consumen carne y es natural natural que hagamos lo mismo\'...\"\n            className=\"flex-1 bg-zinc-950/60 border border-zinc-800 focus:border-zinc-700 rounded-2xl px-5 py-4 text-xs font-sans placeholder-zinc-550 text-white outline-none focus:ring-1 focus:ring-zinc-700/50 transition-all\"\n            disabled={loading}\n          />\n          <button\n            onClick={() => handleOnSubmit(\"\")}\n            disabled={loading || !userInput.trim()}\n            className=\"px-6 py-4 rounded-2xl bg-zinc-100 hover:bg-zinc-200 text-zinc-950 font-semibold text-xs flex items-center gap-2 transition-all disabled:opacity-40 disabled:cursor-not-allowed cursor-pointer\"\n          >\n            {loading ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : <Send className=\"w-4 h-4\" />}\n            {loading ? \"Analizando\" : \"Someter\"}\n          </button>\n        </div>\n\n        {/* Suggestion presets */}\n        <div className=\"space-y-1.5\">\n          <span className=\"text-[10px] font-mono text-zinc-500 uppercase tracking-widest block font-bold\">\n            Ejemplos cl\303\241sicos para testear:\n          </span>\n          <div className=\"flex flex-wrap gap-2\">\n            {PRESET_EXCUSAS.map((preset, i) => (\n              <button\n                key={i}\n                type=\"button\"\n                onClick={() => {\n                  setUserInput(preset);\n                  handleOnSubmit(preset);\n                }}\n                disabled={loading}\n                className=\"text-xs px-3.5 py-2 rounded-xl bg-zinc-950 hover:bg-zinc-900 hover:text-white text-zinc-400 border border-zinc-800/80 transition-all flex items-center gap-1.5 hover:border-zinc-700 text-left\"\n              >\n                <PlusCircle className=\"w-3.5 h-3.5 text-zinc-550 shrink-0\" />\n                {preset}\n              </button>\n            ))}\n          </div>\n        </div>\n      </div>\n\n      {/* Loading Block */}\n      {loading && (\n        <div className=\"bg-zinc-950/20 p-12 border border-zinc-850 rounded-3xl flex flex-col items-center justify-center text-center space-y-4\">\n          <Loader2 className=\"w-10 h-10 animate-spin text-zinc-500\" />\n          <div className=\"space-y-1\">\n            <h4 className=\"text-sm font-semibold text-white tracking-tight\">Diseccionando premisas l\303\263gicas...</h4>\n            <p className=\"text-xs text-zinc-500 font-light max-w-sm\">Evaluando nocicepci\303\263n, termodin\303\241mica y buscando sesgos l\303\263gicos con la IA de Sitiens.</p>\n          </div>\n        </div>\n      )}\n\n      {/* Error state */}\n      {error && (\n        <div className=\"bg-red-500/10 border border-red-500/20 rounded-2xl p-4 flex gap-3 text-xs text-red-400\">\n          <AlertCircle className=\"w-5 h-5 shrink-0\" />\n          <div className=\"space-y-1\">\n            <span className=\"font-semibold block\">Error de deconstrucci\303\263n</span>\n            <span>{error}</span>\n          </div>\n        </div>\n      )}\n\n      {/* Structured report representation */}\n      <AnimatePresence>\n        {analysis && !loading && (\n          <motion.div\n            initial={{ opacity: 0, y: 15 }}\n            animate={{ opacity: 1, y: 0 }}\n            exit={{ opacity: 0, scale: 0.98 }}\n            transition={{ duration: 0.35 }}\n            className=\"space-y-6 w-full\"\n          >\n            <div className=\"border border-zinc-800 rounded-3xl overflow-hidden bg-zinc-950/40\">\n              \n              {/* Header Box */}\n              <div className=\"bg-zinc-900/35 border-b border-zinc-800 p-6 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4\">\n                <div className=\"space-y-1\">\n                  <span className=\"text-[10px] font-mono tracking-widest text-zinc-500 uppercase flex items-center gap-1 font-bold\">\n                    <Workflow className=\"w-3.5 h-3.5 text-zinc-500\" /> DIAGN\303\223STICO DIAL\303\211CTICO SITIENS\n                  </span>\n                  <h3 className=\"text-lg font-bold text-white tracking-tight leading-normal\">\n                    &ldquo;{analysis.argumentSummary}&rdquo;\n                  </h3>\n                </div>\n                <div className=\"flex items-center gap-2\">\n                  <span className=\"text-[10px] font-mono px-2.5 py-1 rounded bg-purple-500/10 text-purple-400 border border-purple-500/20\">\n                    Sintaxis: Deconstruida\n                  </span>\n                </div>\n              </div>\n\n              {/* Body Modules */}\n              <div className=\"p-6 grid grid-cols-1 lg:grid-cols-12 gap-8 text-xs font-light\">\n                \n                {/* Section A: Axioms */}\n                <div className=\"lg:col-span-5 space-y-4\">\n                  \n                  {/* Axiomas list */}\n                  <div className=\"space-y-2 bg-zinc-950/40 p-4 rounded-xl border border-zinc-850\">\n                    <h4 className=\"text-xs font-semibold tracking-wider font-mono text-zinc-330 uppercase flex items-center gap-1.5 border-b border-zinc-900 pb-1.5 mb-2\">\n                      <ShieldAlert className=\"w-3.5 h-3.5 text-orange-400\" />\n                      Axiomas Impl\303\255citos No Examinados\n                    </h4>\n                    <p className=\"text-[11px] text-zinc-500 leading-relaxed mb-3\">\n                      Estas son las verdades absolutas que tu mente da por v\303\241lidas autom\303\241ticamente para sostener tu justificaci\303\263n sin que te de cuenta:\n                    </p>\n                    <ul className=\"space-y-1.5\">\n                      {analysis.axioms.map((ax, i) => (\n                        <li key={i} className=\"flex items-center gap-2 text-zinc-300 bg-zinc-900/40 px-3 py-1.5 rounded-lg border border-zinc-800/40\">\n                          <CheckCircle2 className=\"w-3.5 h-3.5 text-zinc-600 shrink-0\" />\n                          <span>{ax}</span>\n                        </li>\n                      ))}\n                    </ul>\n                  </div>\n\n                  {/* Accuracy ratings */}\n                  <div className=\"space-y-2 bg-zinc-950/40 p-4 rounded-xl border border-zinc-850\">\n                    <h4 className=\"text-xs font-semibold tracking-wider font-mono text-zinc-330 uppercase flex items-center gap-1.5 border-b border-zinc-900 pb-1.5 mb-2\">\n                      <FileText className=\"w-3.5 h-3.5 text-blue-400\" />\n                      Precisi\303\263n Cient\303\255fica Real\n                    </h4>\n                    <div className=\"flex items-center gap-2 mb-2\">\n                      <span className=\"text-[10px] font-mono px-2.5 py-0.5 rounded uppercase font-bold bg-zinc-900 border border-zinc-800 text-zinc-300\">\n                        Calificaci\303\263n: {analysis.scientificAccuracy.rating}\n                      </span>\n                    </div>\n                    <p className=\"text-[11px] text-zinc-400/90 leading-relaxed font-light\">\n                      {analysis.scientificAccuracy.analysis}\n                    </p>\n                  </div>\n\n                </div>\n\n                {/* Section B: Logical errors and environmental metrics */}\n                <div className=\"lg:col-span-7 space-y-6 flex flex-col justify-between\">\n                  \n                  {/* Logical fallacies */}\n                  <div className=\"space-y-2 bg-zinc-950/40 p-4 rounded-xl border border-zinc-850\">\n                    <h4 className=\"text-xs font-semibold tracking-wider font-mono text-zinc-330 uppercase flex items-center gap-1.5 border-b border-zinc-900 pb-1.5 mb-2\">\n                      <Compass className=\"w-3.5 h-3.5 text-pink-400\" />\n                      Deconstrucci\303\263n Dial\303\251ctica y Sesgos\n                    </h4>\n                    <div className=\"space-y-3 font-light text-zinc-400\">\n                      {analysis.logicalFailures.map((fail, i) => (\n                        <p key={i} className=\"text-zinc-400 leading-relaxed text-xs\">\n                          {fail}\n                        </p>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* Impact split details */}\n                  <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                    \n                    {/* Animal suffering */}\n                    <div className=\"bg-zinc-950/40 p-4 rounded-xl border border-zinc-850 space-y-2\">\n                      <div className=\"flex items-center gap-1.5 text-red-400 font-medium font-mono text-[10px] tracking-wider uppercase\">\n                        <Activity className=\"w-3.5 h-3.5 text-red-500 animate-pulse\" />\n                        Variables de Sintiendo Aludidas\n                      </div>\n                      <p className=\"text-[10.5px] text-zinc-400 leading-relaxed font-light\">\n                        {analysis.impactAnalysis.sintiente}\n                      </p>\n                    </div>\n\n                    {/* Green impact */}\n                    <div className=\"bg-zinc-950/40 p-4 rounded-xl border border-zinc-850 space-y-2\">\n                      <div className=\"flex items-center gap-1.5 text-emerald-400 font-medium font-mono text-[10px] tracking-wider uppercase\">\n                        <Flame className=\"w-3.5 h-3.5 text-emerald-500\" />\n                        Desgaste T\303\251rmico Colateral\n                      </div>\n                      <p className=\"text-[10.5px] text-zinc-400 leading-relaxed font-light\">\n                        {analysis.impactAnalysis.ecosistemic}\n                      </p>\n                    </div>\n\n                  </div>\n\n                </div>\n\n              </div>\n\n              {/* Socratic concluding reflection */}\n              <div className=\"bg-zinc-900/40 p-6 border-t border-zinc-800 text-center space-y-3 relative overflow-hidden\">\n                <div className=\"absolute left-6 top-1/2 -translate-y-1/2 opacity-[0.02] text-white pointer-events-none\">\n                  <Brain className=\"w-24 h-24\" />\n                </div>\n                <div className=\"flex items-center justify-center gap-1.5 text-zinc-400 text-[10px] font-mono tracking-widest uppercase\">\n                  <Sparkles className=\"w-3 h-3 text-amber-500\" />\n                  PREGUNTA SOCR\303\201TICA FINAL SITIENS:\n                </div>\n                <p className=\"text-sm md:text-base font-serif italic text-zinc-100 max-w-2xl mx-auto leading-relaxed\">\n                  &ldquo;{analysis.alternativeReflection}&rdquo;\n                </p>\n              </div>\n\n            </div>\n          </motion.div>\n        )}\n      </AnimatePresence>\n    </div>\n  );\n}"
    }
