  file_change {
    absolute_path_uri: "file:///src/types.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "export type ConsensusType = \"CONSENSO\" | \"ESCENARIO_GRIS\" | \"DILEMA\" | \"FALACIA\";\n\nexport interface NodeDetail {\n  id: string;\n  category: \"sintiencia\" | \"historia\" | \"clima\" | \"eleccion\";\n  title: string;\n  shortDesc: string;\n  longDesc: string;\n  scientificFacts: string[];\n  connections: string[]; // connects to other node IDs\n}\n\nexport interface DilemmaDetail {\n  id: string;\n  category: \"sintiencia\" | \"historia\" | \"clima\" | \"eleccion\";\n  title: string;\n  popularStatement: string;\n  consensus: ConsensusType;\n  scientificDeconstruction: string;\n  philosophicalDeconstruction: string;\n  coexistenceImpact: string;\n}\n\nexport const CORE_NODES: NodeDetail[] = [\n  // SINTIENCIA\n  {\n    id: \"dolor-fisico\",\n    category: \"sintiencia\",\n    title: \"El Dolor F\303\255sico y el SNC\",\n    shortDesc: \"La presencia demostrada de sistema nervioso central y nociceptores hom\303\263logos en vertebrados.\",\n    longDesc: \"La nocicepci\303\263n es la capacidad de detectar un da\303\261o tisular nocivo. La neurobiolog\303\255a moderna confirma que todos los vertebrados (mam\303\255feros, aves, reptiles, anfibios, peces) poseen un sistema nervioso central, receptores de dolor (nociceptores) y v\303\255as cerebrales complejas (como el t\303\241lamo y el c\303\263rtex frontal) capaces de traducir los impulsos electroqu\303\255micos en una experiencia subjetiva consciente de dolor y estr\303\251s psicol\303\263gico.\",\n    scientificFacts: [\n      \"Los animales muestran conductas de evitaci\303\263n condicionada, automedicaci\303\263n analg\303\251sica y cambios en la frecuencia card\303\255aca ante dolor estimulado.\",\n      \"La Declaraci\303\263n de Cambridge sobre la Conciencia (2012) afirma formalmente que los animales no humanos tienen los sustratos neuroanat\303\263micos para generar conciencia de s\303\255 y de su entorno.\"\n    ],\n    connections: [\"zonas-grises\", \"frontera-vegetal\", \"disonancia-placer\"]\n  },\n  {\n    id: \"zonas-grises\",\n    category: \"sintiencia\",\n    title: \"Zonas Grises: Bivalvos e Insectos\",\n    shortDesc: \"El debate del procesamiento del dolor en seres sin encefalizaci\303\263n compleja.\",\n    longDesc: \"En las fronteras de la sintiencia animal se encuentran organismos como los moluscos bivalvos (mejillones, ostras) e insectos. Mientras que los bivalvos carecen de enc\303\251falo central y nocicepci\303\263n demostrada (poseen ganglios neurales simples que responden a est\303\255mulos de forma refleja), los insectos muestran comportamientos de escape m\303\241s complejos, pero con un procesamiento de dolor a\303\272n cuestionado. Representa un espacio estimulante de debate moral donde se suele aplicar el \'Principio de Precauci\303\263n\'.\",\n    scientificFacts: [\n      \"Los bivalvos no tienen receptores de dolor ni emiten respuestas neuroqu\303\255micas complejas de estr\303\251s que se asocien a la sintiencia cerebral.\",\n      \"Ciertos insectos demuestran comportamientos de autocuidado tras lesiones, pero su cerebro descentralizado desaf\303\255a la definici\303\263n antropom\303\263rfica de la experiencia del sufrimiento.\"\n    ],\n    connections: [\"dolor-fisico\", \"frontera-vegetal\", \"metano-emisiones\"]\n  },\n  {\n    id: \"frontera-vegetal\",\n    category: \"sintiencia\",\n    title: \"La Frontera Vegetal\",\n    shortDesc: \"Por qu\303\251 las respuestas bioqu\303\255micas de las plantas no equivalen a la conciencia del dolor.\",\n    longDesc: \"Existe una tendencia com\303\272n a equiparar las respuestas adaptativas de las plantas (como emitir compuestos vol\303\241tiles tras ser cortadas) con el dolor f\303\255sico animal. No obstante, la ciencia demuestra que esta es una reacci\303\263n mec\303\241nica, electroqu\303\255mica y hormonal refleja que carece de procesamiento cognitivo, ya que las plantas no disponen de sistema nervioso central, cerebro ni redes nociceptivas para experimentar dolor subjetivo.\",\n    scientificFacts: [\n      \"Las plantas reaccionan biol\303\263gicamente de la misma manera que una c\303\251lula aislada o un sistema metab\303\263lico aut\303\263nomo, sin sustrato cognitivo.\",\n      \"Desde el punto de vista evolutivo, el dolor animal sirve para huir y buscar refugio. Al ser s\303\251siles (incapaces de moverse), el dolor f\303\255sico aportar\303\255a un elevado coste metab\303\263lico sin beneficio evolutivo directo para las plantas.\"\n    ],\n    connections: [\"dolor-fisico\", \"zonas-grises\", \"recursos-termo\"]\n  },\n\n  // HISTORIA\n  {\n    id: \"animal-herramienta\",\n    category: \"historia\",\n    title: \"El Animal como Herramienta\",\n    shortDesc: \"La subordinaci\303\263n animal como la infraestructura biol\303\263gica que levant\303\263 la civilizaci\303\263n.\",\n    longDesc: \"Desde la domesticaci\303\263n primitiva en el Neol\303\255tico, los animales no humanos han actuado como la infraestructura muscular, log\303\255stica, textil y nutricional de las primeras civilizaciones. El arado arrastrado por bueyes, el transporte por caballos y el uso de abono org\303\241nico sentaron las bases del sedentarismo humano. El animal se configur\303\263 hist\303\263ricamente como una herramienta de rendimiento tecnol\303\263gico antes de ser considerado un fin moral aut\303\263nomo.\",\n    scientificFacts: [\n      \"El crecimiento cerebral humano dependi\303\263 inicialmente de la densidad cal\303\263rica de las grasas cocinadas antes del desarrollo agr\303\255cola sustentable.\",\n      \"La expansi\303\263n del Imperio Romano y las rutas de la seda habr\303\255an sido f\303\255sicamente imposibles sin la tracci\303\263n y la log\303\255stica animal.\"\n    ],\n    connections: [\"evolucion-dieta\", \"domesticacion-industrial\", \"suplementacion-progreso\"]\n  },\n  {\n    id: \"evolucion-dieta\",\n    category: \"historia\",\n    title: \"Evoluci\303\263n y Nutrici\303\263n Hist\303\263rica\",\n    shortDesc: \"El papel que jug\303\263 el canibalismo cal\303\263rico y el procesamiento de grasas en nuestra anatom\303\255a.\",\n    longDesc: \"El Homo sapiens evolucion\303\263 biol\303\263gicamente como un omn\303\255voro vers\303\241til. El consumo espor\303\241dico e hist\303\263rico de carne aport\303\263 nutrientes ultraconcentrados esenciales en un entorno de escasez severa, liberando energ\303\255a metab\303\263lica que facilit\303\263 el crecimiento e hipertrofia del cerebro humano (conforme a la hip\303\263tesis del tejido costoso). Esta adaptaci\303\263n hist\303\263rica, sin embargo, chocar\303\241 posteriormente con la disponibilidad excesiva de recursos de las urbes modernas.\",\n    scientificFacts: [\n      \"La evoluci\303\263n redujo la longitud de nuestro tracto digestivo digestivo comparado con primates herb\303\255voros estrictos para digerir grasas y carnes con mayor eficiencia cal\303\263rica.\",\n      \"La necesidad hist\303\263rica de densidades energ\303\251ticas extremas se ha vuelto redundante hoy en d\303\255a con las dietas planificadas modernas y los canales de distribuci\303\263n.\"\n    ],\n    connections: [\"animal-herramienta\", \"suplementacion-progreso\", \"disonancia-placer\"]\n  },\n  {\n    id: \"domesticacion-industrial\",\n    category: \"historia\",\n    title: \"Domesticaci\303\263n e Industria Intensiva\",\n    shortDesc: \"La gran mutaci\303\263n: de la convivencia utilitaria al sistema masivo de conversi\303\263n cal\303\263rica.\",\n    longDesc: \"A mediados del siglo XX, la automatizaci\303\263n y los conocimientos sobre microbiolog\303\255a propiciaron el nacimiento de la ganader\303\255a industrial intensiva. Los animales fueron extirpados de los ecosistemas tradicionales y reubicados en macrogranjas configuradas como f\303\241bricas de ensamblaje. Su valor f\303\241ctico se redujo a variables de tasa de conversi\303\263n alimenticia por kilo, someti\303\251ndolos a ritmos de confinamiento biol\303\263gicamente aberrantes.\",\n    scientificFacts: [\n      \"Se sacrifican m\303\241s de 70.000 millones de animales terrestres anualmente, en instalaciones optimizadas puramente en t\303\251rminos de eficiencia cal\303\263rica por unidad de espacio.\",\n      \"El uso indiscriminado de antibi\303\263ticos profil\303\241cticos en estas plantas representa el 70% del uso global de f\303\241rmacos, acelerando la resistencia bacteriana.\"\n    ],\n    connections: [\"animal-herramienta\", \"metano-emisiones\", \"deforestacion-ecosist\"]\n  },\n\n  // CLIMA\n  {\n    id: \"recursos-termo\",\n    category: \"clima\",\n    title: \"La Termodin\303\241mica del Despilfarro\",\n    shortDesc: \"La baja eficiencia energ\303\251tica de filtrar nutrientes vegetales a trav\303\251s de seres sintientes.\",\n    longDesc: \"Desde una perspectiva termodin\303\241mica, la ganader\303\255a act\303\272a como uno de los sumideros energ\303\251ticos m\303\241s ineficientes del planeta. Para producir 1 kilo de carne de ternera se necesitan hasta 12 o 16 kilos de grano vegetal. Esto implica desperdiciar aproximadamente el 90% de la energ\303\255a biol\303\263gica inicial alimentando el metabolismo propio del animal, sus huesos, calor corporal y deposiciones, en vez de destinar ese grano vegetal para el consumo directo humano.\",\n    scientificFacts: [\n      \"Alimentar directamente a la humanidad con cultivos vegetales liberar\303\255a hasta un 75% de las tierras de cultivo mundiales.\",\n      \"Aproximadamente el 80% de las tierras agr\303\255colas de la Tierra se dedican parcial o totalmente al ganado, pero este solo proporciona el 18% de las calor\303\255as que consume la especie humana.\"\n    ],\n    connections: [\"frontera-vegetal\", \"metano-emisiones\", \"deforestacion-ecosist\"]\n  },\n  {\n    id: \"metano-emisiones\",\n    category: \"clima\",\n    title: \"Gases de Efecto Invernadero y Metano\",\n    shortDesc: \"El impacto devastador de los gases ent\303\251ricos de efecto invernadero r\303\241pido.\",\n    longDesc: \"La ganader\303\255a intensiva y extensiva es responsable de alrededor de un 14.5% a un 18% de las emisiones antropog\303\251nicas mundiales de gases de efecto Invernadero (GEI). La digesti\303\263n ent\303\251rica de rumiantes genera emisiones masivas de gas metano (CH4), un compuesto con un potencial de calentamiento global hasta 28 a 34 veces superior al del di\303\263xido de carbono (CO2) en una escala de 100 a\303\261os.\",\n    scientificFacts: [\n      \"El metano permanece menos tiempo en la atm\303\263sfera que el CO2 pero genera un forzamiento radiactivo inmediato que acelera la velocidad de desestabilizaci\303\263n clim\303\241tica.\",\n      \"Las emisiones colectivas del ganado equivalen aproximadamente al volumen emitido por todo el sector del transporte global (aviones, trenes, barcos y camiones combinados).\"\n    ],\n    connections: [\"recursos-termo\", \"deforestacion-ecosist\", \"domesticacion-industrial\"]\n  },\n  {\n    id: \"deforestacion-ecosist\",\n    category: \"clima\",\n    title: \"Devastaci\303\263n de Ecosistemas y Deforestaci\303\263n\",\n    shortDesc: \"La sustituci\303\263n masiva de ecosistemas v\303\255rgenes por monocultivos de soja forrajera.\",\n    longDesc: \"Para sostener la demanda mundial de carne barata, se talan millones de hect\303\241reas de bosques y selvas tropicales v\303\255rgenes (como la cuenca amaz\303\263nica). Esos terrenos se destinan al pastoreo de ganado o a monocultivos gigantes de soja transg\303\251nica altamente dependientes de plaguicidas. Esto desencadena un colapso irreversible de biodiversidad end\303\251mica y elimina sumideros de carbono vitales frente a la crisis clim\303\241tica.\",\n    scientificFacts: [\n      \"La ganader\303\255a extensiva y extensiva estimula m\303\241s de un 70% de la deforestaci\303\263n de la selva del Amazonas.\",\n      \"La p\303\251rdida r\303\241pida de biodiversidad sit\303\272a el planeta en la sexta extinci\303\263n masiva de especies terrestres de la historia f\303\255sica de la Tierra.\"\n    ],\n    connections: [\"recursos-termo\", \"metano-emisiones\", \"domesticacion-industrial\"]\n  },\n\n  // ELECCION\n  {\n    id: \"disonancia-placer\",\n    category: \"eleccion\",\n    title: \"Disonancia Cognitiva y Placer\",\n    shortDesc: \"Por qu\303\251 amamos a unos seres vivos y nos sentamos en la mesa a devorar a otros.\",\n    longDesc: \"El ser humano moderno manifiesta una profunda disonancia cognitiva moral. Desarrollamos sentimientos de gran empat\303\255a y cuidado por animales de compa\303\261\303\255a (perros, gatos, caballos) a los que dotamos de valor intr\303\255nseco y derechos, mientras que financiamos de forma indirecta el confinamiento de cerdos, gallinas o terneros que ostentan capacidades neurol\303\263gicas an\303\241logas de experimentar dolor y apego social. El sabor, el placer y la tradici\303\263n cultural act\303\272an como la anestesia mental contra esta inconsistencia moral interna.\",\n    scientificFacts: [\n      \"Estudios etol\303\263gicos revelan que los cerdos superan a los perros en ciertas tareas de resoluci\303\263n l\303\263gica de problemas y tienen una autoconciencia cognitiva sofisticada.\",\n      \"La disonancia moral se gestiona mediante la \'paradoja de la carne\': racionalizamos el consumo despojando mentalmente de sintiencia y personalidad cognitiva a los animales de granja.\"\n    ],\n    connections: [\"dolor-fisico\", \"evolucion-dieta\", \"axiomas-morales\"]\n  },\n  {\n    id: \"suplementacion-progreso\",\n    category: \"eleccion\",\n    title: \"Suplementaci\303\263n y Progreso Tecnol\303\263gico\",\n    shortDesc: \"C\303\263mo la biotecnolog\303\255a moderna nos independiza finalmente de la depredaci\303\263n biol\303\263gica.\",\n    longDesc: \"Por primera vez en millones de a\303\261os de evoluci\303\263n biogen\303\251tica, la especie humana dispone de un sistema de s\303\255ntesis bacteriana capaz de producir vitamina B12 (cobalamina) sin necesidad de sacrificar o parasitar animales. El progreso industrial y los alimentos enriquecidos rompen el lazo de la necesidad nutricional f\303\241ctica de los omn\303\255voros, trasladando de inmediato el debate diet\303\251tico directo del terreno biol\303\263gico inevitable al \303\241mbito \303\251tico voluntario.\",\n    scientificFacts: [\n      \"La vitamina B12 de origen animal se origina realmente en las bacterias del suelo antes de ser asimilada por el animal; el ganado industrial moderno es de hecho suplementado con cobalamina de laboratorio debido al desgaste industrial de los campos agrarios.\",\n      \"La biotecnolog\303\255a alimentaria moderna nos dota de un control absoluto para formular una nutrici\303\263n balanceada y \303\263ptima basada 100% en plantas.\"\n    ],\n    connections: [\"evolucion-dieta\", \"animal-herramienta\", \"axiomas-morales\"]\n  },\n  {\n    id: \"axiomas-morales\",\n    category: \"eleccion\",\n    title: \"Los Axiomas Morales de la Alimentaci\303\263n\",\n    shortDesc: \"El choque fundamental de ideales: la evitaci\303\263n del dolor individual frente a la supremac\303\255a antropog\303\251nica.\",\n    longDesc: \"Las decisiones humanas sobre la comida residen sobre ideales \303\251ticos fundamentales y a menudo inconscientes. Por un lado, el utilitarismo sintiente argumenta que causar da\303\261o severo para obtener un beneficio menor (placer sensorial ef\303\255mero) es inmoral. Por otro lado, la supremac\303\255a antropoc\303\251ntrica sit\303\272a al Homo sapiens como el \303\272nico depositario de dignidad moral al ostentar habilidades abstractas, relegando el resto de las vidas f\303\241cticas a meras mercanc\303\255as sustituibles de mercado.\",\n    scientificFacts: [\n      \"La filosof\303\255a contempor\303\241nea defiende que si un ser \'siente un dolor que le importa a s\303\255 mismo\', privarlo de experimentar bienestar futuro requiere un motivo f\303\241ctico de subsistencia real o fuerza mayor, no mero capricho est\303\251tico u ocio.\",\n      \"El cuestionamiento de los axiomas tradicionales constituye el primer paso para salir de la par\303\241lisis social y asumir acciones individuales coherentes.\"\n    ],\n    connections: [\"disonancia-placer\", \"suplementacion-progreso\", \"dolor-fisico\"]\n  }\n];\n\nexport const DILEMMAS_DATA: DilemmaDetail[] = [\n  {\n    id: \"leones-carne\",\n    category: \"historia\",\n    title: \"El Argumento de la Cadena Tr\303\263fica\",\n    popularStatement: \"Los leones comen carne en la naturaleza, por tanto es natural que los seres humanos hagamos lo mismo.\",\n    consensus: \"FALACIA\",\n    scientificDeconstruction: \"Los felinos obligatorios carecen de la capacidad fisiol\303\263gica para sintetizar ciertos amino\303\241cidos y l\303\255pidos de origen vegetal, siendo carn\303\255voros biol\303\263gicos estrictos. El ser humano, en cambio, es un omn\303\255voro flexible que asimila con excelente rendimiento de salud todos los macronutrientes de fuentes vegetales. Adem\303\241s, los animales no crean industrias de tortura, no modifican gen\303\251ticamente a sus presas ni sostienen macrogranjas masivas destructivas sobre la biosfera.\",\n    philosophicalDeconstruction: \"Este razonamiento cae directamente en la \'Falacia Naturalista\' o ley de Hume: asumir que \'lo que es\' en la naturaleza determina inmediatamente \'lo que debe ser\' en el terreno \303\251tico. Un le\303\263n carece de racionalidad moral y no puede ser juzgado por sus actos depredadores. Los humanos, al gozar de capacidad de juicio \303\251tico, decisiones deliberadas y suplementos nutricionales, no podemos justificar decisiones morales bas\303\241ndonos en comportamientos instintivos o salvajes.\",\n    coexistenceImpact: \"Relegarse a la cadena tr\303\263fica salvaje para justificar la destrucci\303\263n artificial industrial de 70.000 millones de vidas es una renuncia voluntaria al libre albedr\303\255o y al discernimiento humanitario.\"\n  },\n  {\n    id: \"plantas-sienten-dolor\",\n    category: \"sintiencia\",\n    title: \"La Sensibilidad de las Plantas\",\n    popularStatement: \"Las plantas tambi\303\251n sienten dolor al ser cosechadas, as\303\255 que comer lechuga es igual que comer ternera.\",\n    consensus: \"FALACIA\",\n    scientificDeconstruction: \"Las plantas reaccionan a agresiones mediante se\303\261ales qu\303\255micas, el\303\251ctricas u hormonales autom\303\241ticas (como emitir \303\241cido jasm\303\263nico o gases etil\303\251nicos). Estas respuestas bioqu\303\255micas reflejas carecen de traducci\303\263n cognitiva subjetiva. Las plantas carecen de nociceptores, sistema nervioso centralizado y cerebro, indispensables para que esas se\303\261ales el\303\251ctricas se perciban intelectualmente como \'dolor\' o \'sufrimiento\'.\",\n    philosophicalDeconstruction: \"Incluso si acept\303\241semos hipot\303\251ticamente el absurdo cient\303\255fico de que las plantas sufren, el omnivorismo humano seguir\303\255a devorando hasta 10 veces m\303\241s vidas vegetales que una dieta vegetal directa. Esto se debe a la ineficiencia termodin\303\241mica del ganado, que necesita comer toneladas de soja y pasto para generar un solo kilo de m\303\272sculo del que alimentarse. La minimizaci\303\263n del da\303\261o exige reducir el intermediario c\303\241rnico.\",\n    coexistenceImpact: \"Equiparar la defensa bioqu\303\255mica refleja de un vegetal que no ostenta conciencia con el sufrimiento consciente y el trauma relacional de una vaca o un cerdo delata una profunda simplificaci\303\263n.\"\n  },\n  {\n    id: \"bivalvos-ostras\",\n    category: \"sintiencia\",\n    title: \"El Dilema de los Bivalvos\",\n    popularStatement: \"\302\277Es moralmente aceptable el consumo de bivalvos como mejillones u ostras con total tranquilidad?\",\n    consensus: \"ESCENARIO_GRIS\",\n    scientificDeconstruction: \"Los bivalvos (mejillones, almejas, ostras) son moluscos s\303\251siles extremadamente simples. Carecen de enc\303\251falo central, cerebro o sistema nervioso centralizado; tan solo ostentan una red descentralizada de ganglios neurales sencillos. La biolog\303\255a no halla indicios de nocicepci\303\263n activa ni estr\303\251s doloroso an\303\241logo al de los vertebrados. Adem\303\241s, su cultivo no requiere forraje, filtra agua y genera una huella de carbono sumamente diminuta.\",\n    philosophicalDeconstruction: \"Este es un conflicto \303\251tico que divide posturas. El pragmatismo utilitarista afirma que consumir bivalvos es perfectamente correcto, pues no genera dolor neto en el universo y reduce el impacto de otros cultivos de plantas que s\303\255 exigen recolecci\303\263n mecanizada peligrosa para roedores en el campo. El abolicionismo, en cambio, defiende el principio de precauci\303\263n: ante la falta de una certeza experimental absoluta de amoralidad, es preferible no considerarlos mercanc\303\255as mercantiles comestibles.\",\n    coexistenceImpact: \"Un \303\241rea gris f\303\251rtil que demuestra que trazar la l\303\255nea requiere evaluar con tremenda humildad la graduaci\303\263n de la conciencia biol\303\263gica humana y animal.\"\n  },\n  {\n    id: \"granja-feliz-ecologia\",\n    category: \"eleccion\",\n    title: \"El Argumento de la Granja Feliz\",\n    popularStatement: \"Consumir animales criados en libertad (ganader\303\255a ecol\303\263gica) y sacrificados con m\303\251todos indoloros no tiene nada de malo.\",\n    consensus: \"DILEMA\",\n    scientificDeconstruction: \"Aunque en la ganader\303\255a ecol\303\263gica tradicional el animal dispone de un bienestar diario infinitamente superior al infierno industrial, el sacrificio se ejecuta a una edad extremadamente temprana comparada con su longevidad biol\303\263gica natural. Una vaca es sacrificada antes de los 2 a\303\261os de vida, cuando podr\303\255a llegar a vivir de forma saludable unos 20 a\303\261os. Adem\303\241s, este modelo de pastoreo extensivo requiere una superficie de tierra tan gigantesca que es f\303\255sicamente inviable para nutrir a la humanidad.\",\n    philosophicalDeconstruction: \"Este es el n\303\272cleo de la paradoja de la muerte indolora (Epicure\303\255smo vs Teor\303\255a de la Privaci\303\263n). El bienestarismo afirma que una vaca recibe una existencia digna que de otro modo nunca habr\303\255a disfrutado, de modo que su balance vital es positivo. El abolicionismo de derechos r\303\251plica que, aunque no haya dolor f\303\255sico f\303\241ctico al morir, matar al animal lo priva injustamente de un futuro repleto de experiencias vitales agradables por puro ociosidad sensorial humana.\",\n    coexistenceImpact: \"Una tensi\303\263n directa entre admitir que los animales son sujetos con valor intr\303\255nseco e irremplazables ante el universo, o meros recipientes de bienestar intercambiables.\"\n  },\n  {\n    id: \"conservacion-dehesas\",\n    category: \"clima\",\n    title: \"La Paradoja de la Ganader\303\255a Sostenible\",\n    popularStatement: \"Si eliminamos el ganado, ecosistemas protegidos como la dehesa ib\303\251rica o las de monta\303\261a desaparecer\303\255an por completo.\",\n    consensus: \"DILEMA\",\n    scientificDeconstruction: \"Ecosistemas antr\303\263picos como las dehesas mediterr\303\241neas o las praderas alpinas de alta monta\303\261a dependen del pastoreo de ganado rumiante para conservar su equilibrio de biodiversidad, limpiar matorrales de cara a frenar incendios incontrolables y reciclar fertilidad en el suelo local. Eliminar dr\303\241sticamente este ganado degradar\303\255a estos paisajes, destruyendo directamente el h\303\241bitat id\303\263neo de cientos de especies de aves, insectos, polinizadores y flora.\",\n    philosophicalDeconstruction: \"Este es un conflicto \303\251tico brutal entre el enfoque \'individualista\' (inter\303\251s moral de la vaca individual a no ser explotada) y el enfoque \'ecoc\303\251ntrico\' (deber de conservar el ecosistema colectivo, el paisaje com\303\272n y su biodiversidad integrada). Al priorizar lo ecoc\303\251ntrico, el pastoreo de carne en baja densidad es una herramienta simbi\303\263tica noble; al priorizar lo individual, es uso il\303\255cito del ser sintiente.\",\n    coexistenceImpact: \"Nos sit\303\272a delante del espejo m\303\241s \303\241spero: a veces proteger la integridad global de la biosfera choca con nuestros mandatos absolutos de derechos individuales.\"\n  },\n  {\n    id: \"comer-insectos-harinas\",\n    category: \"eleccion\",\n    title: \"La Apuesta del Consumo de Insectos\",\n    popularStatement: \"La entomofagia (ingerir grillos o gusanos) es el sustituto ideal de la ganader\303\255a barata para proteger el cambio clim\303\241tico.\",\n    consensus: \"ESCENARIO_GRIS\",\n    scientificDeconstruction: \"La producci\303\263n de prote\303\255nas a base de harinas de insectos es termodin\303\241micamente colosalmente m\303\241s eficiente que los mam\303\255feros, emitiendo un 99% menos de metano y consumiendo apenas agua y territorio f\303\251rtil. Sin embargo, la ciencia a\303\272n debate las complejidades sintientes de los artr\303\263podos: demuestran aprendizaje, pero se sospecha que sus respuestas neurales son predominantemente reflejas, sin la presencia de dolor emocional conscientes.\",\n    philosophicalDeconstruction: \"Si el dolor es nulo o m\303\255nimo, esta pr\303\241ctica es una alternativa maravillosa para erradicar las destructivas macrogranjas a escala barata. Para el veganismo abolicionista absoluto, cultivar insectos por millardos en jaulas mecanizadas sigue perpetuando al ser humano como amo, se\303\261or y manipulador absoluto del resto de las vidas biol\303\263gicas sintientes cerebrales del planeta.\",\n    coexistenceImpact: \"Un portal h\303\255brido fascinante donde la urgencia de salvar la biosfera del cambio clim\303\241tico se enfrenta a nuestras teor\303\255as sobre las microconciencias neurales.\"\n  },\n  {\n    id: \"humanos-caninos-biologia\",\n    category: \"historia\",\n    title: \"La Dentadura y Caninos Humanos\",\n    popularStatement: \"Nuestros dientes tienen caninos (colmillos), lo que demuestra biol\303\263gicamente que estamos hechos para triturar carne.\",\n    consensus: \"FALACIA\",\n    scientificDeconstruction: \"Los colmillos o caninos humanos son morfol\303\263gica y fisiol\303\263gicamente inapropiados para la desgarradura de pieles y huesos de presas salvajes, comparados con la dentadura de mam\303\255feros carn\303\255voros verdaderos (gatos, leones). De hecho, nuestros caninos son protuberancias reducidas vestigiales de una herencia evolutiva hom\303\255nida, adaptados f\303\241cticamente para pelar frutos duros o vegetales, mientras que nuestros molares planos est\303\241n optimizados para trillar grano.\",\n    philosophicalDeconstruction: \"Considerar que una caracter\303\255stica morfol\303\263gica f\303\255sica de valor vestigial o parcial nos impone un mandato \303\251tico obligatorio de alimentaci\303\263n destructiva es una pirueta mental extrema. Al ser agentes dotados de raz\303\263n deliberativa y estanter\303\255as de supermercados repletas de alternativas sanas directas, no podemos justificar decisiones morales bas\303\241ndonos en analog\303\255as dentales limitadas err\303\263neas.\",\n    coexistenceImpact: \"Someter nuestro juicio moral moderno a una tosca malinterpretaci\303\263n de la anatom\303\255a bucal revela la fuerza con la que nos aferramos a racionalizaciones para proteger el h\303\241bito.\"\n  },\n  {\n    id: \"ganaderia-industrial-hecho\",\n    category: \"clima\",\n    title: \"La Ganader\303\255a Industrial es Sostenible\",\n    popularStatement: \"La carne de macrogranjas es necesaria para alimentar al mundo de forma barata y es sostenible con las nuevas tecnolog\303\255as.\",\n    consensus: \"CONSENSO\",\n    scientificDeconstruction: \"La ineficiencia cal\303\263rica estructural de filtrar grano vegetal a trav\303\251s del ganado es inalterable por la f\303\255sica y la digesti\303\263n. La industria intensiva acelera de forma cient\303\255ficamente incuestionable la eutrofizaci\303\263n de acu\303\255feros locales (por purines de cerdos), contamina el suelo mediante amon\303\255aco, consume un volumen colosal de agua dulce y deforesta selvas para piensos, siendo insostenible con cualquier limitaci\303\263n t\303\251rmica planetaria de cara al siglo XXI.\",\n    philosophicalDeconstruction: \"No existe justificaci\303\263n filos\303\263fica seria que defienda someter a miles de millones de seres vivos con demostrada nocicepci\303\263n a un sufrimiento cr\303\263nico masivo diario con el fin de proteger las plusval\303\255as de una industria gastron\303\263mica ineficiente y redundante. Este hecho une a utilitaristas, ecocentristas, defensores de derechos y humanistas en una opini\303\263n un\303\241nime: la macrogranja es una anomal\303\255a \303\251tica aberrante irremediable.\",\n    coexistenceImpact: \"La abolici\303\263n del apoyo financiero pasivo a las macrogranjas constituye el escal\303\263n m\303\255nimo indispensable y urgente de cualquier andamiaje moral humano sincero de hoy.\"\n  }\n];\n"
    }
