          text: "  const [eggs, setEggs] = useState(4); // units"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const [reductionTarget, setReductionTarget] = useState<25 | 50 | 100>(50);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Math coefficients per unit:"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Beef (100g): 18 suffering hours, 6.0kg CO2, 1500L water, 32m2 land"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Pork (100g): 15 suffering hours, 1.2kg CO2, 600L water, 3.2m2 land"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Chicken (100g): 32 suffering hours, 0.7kg CO2, 400L water, 1.5m2 land (high stress density)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Fish (100g): 24 suffering hours, 0.5kg CO2, 120L water, 0.2m2 land"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Dairy (1 Liter): 50 suffering hours, 2.0kg CO2, 1000L water, 4.5m2 land"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Eggs (1 unit): 72 suffering hours, 0.3kg CO2, 200L water, 0.6m2 land (includes cull of male chicks)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const calculateFootprint = ("
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    b: number, "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    pk: number, "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ch: number, "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    f: number, "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    d: number, "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    e: number"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  ): FootprintVals => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const beefMult = b / 100;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const porkMult = pk / 100;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const chickenMult = ch / 100;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const fishMult = f / 105;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const suffering = "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (beefMult * 18) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (porkMult * 15) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (chickenMult * 32) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (fishMult * 24) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (d * 50) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (e * 72);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const co2 = "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (beefMult * 6.0) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (porkMult * 1.2) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (chickenMult * 0.7) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (fishMult * 0.5) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (d * 2.0) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (e * 0.3);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const water = "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (beefMult * 1500) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (porkMult * 600) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (chickenMult * 400) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (fishMult * 120) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (d * 1000) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (e * 200);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const land = "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (beefMult * 32) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (porkMult * 3.2) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (chickenMult * 1.5) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (fishMult * 0.2) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (d * 4.5) + "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      (e * 0.6);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      sufferingHours: Math.round(suffering),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      co2: parseFloat(co2.toFixed(1)),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      water: Math.round(water),"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      land: parseFloat(land.toFixed(1))"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
