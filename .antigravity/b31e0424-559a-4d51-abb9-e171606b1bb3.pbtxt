  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \"react\";\nimport { \n  Compass, \n  Layers, \n  Activity, \n  HelpCircle, \n  Scale, \n  Leaf, \n  Flame, \n  Network, \n  Sparkles, \n  Heart,\n  ChevronRight,\n  TrendingDown,\n  Info\n} from \"lucide-react\";\nimport NetworkGraph from \"./components/NetworkGraph\";\nimport ExcusesDilemmas from \"./components/ExcusesDilemmas\";\nimport ImpactCalculator from \"./components/ImpactCalculator\";\nimport AiValidator from \"./components/AiValidator\";\nimport { motion, AnimatePresence } from \"motion/react\";\n\ntype TabType = \"grafo\" | \"dialectica\" | \"calculadora\" | \"validador\";\n\nexport default function App() {\n  const [activeTab, setActiveTab] = useState<TabType>(\"grafo\");\n  const [passedArgument, setPassedArgument] = useState<string | null>(null);\n\n  const handleDeconstructTrigger = (excuse: string) => {\n    setPassedArgument(excuse);\n    setActiveTab(\"validador\");\n  };\n\n  const handleClearTrigger = () => {\n    setPassedArgument(null);\n  };\n\n  return (\n    <div className=\"min-h-screen bg-zinc-950 font-sans text-zinc-200 selection:bg-zinc-800 selection:text-white flex flex-col justify-between\">\n      {/* Dynamic Upper Ambient Border Glow */}\n      <div className=\"absolute top-0 left-0 right-0 h-[450px] bg-radial from-purple-950/15 via-transparent to-transparent pointer-events-none z-0\" />\n\n      {/* Primary header navbar container */}\n      <header className=\"border-b border-zinc-900 bg-zinc-950/85 backdrop-blur-md sticky top-0 z-50\">\n        <div id=\"navigation-bar\" className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between\">\n          \n          {/* Logo and Identity */}\n          <div className=\"flex items-center gap-3\">\n            <div className=\"w-9 h-9 rounded-xl bg-gradient-to-br from-red-500/10 via-purple-600/10 to-emerald-500/10 border border-zinc-800 flex items-center justify-center relative overflow-hidden group\">\n              <div className=\"absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 transition-opacity\" />\n              <Layers className=\"w-4 h-4 text-zinc-300\" />\n            </div>\n            <div>\n              <h1 className=\"text-sm font-black text-white tracking-widest font-mono uppercase\">SITIENS</h1>\n              <p className=\"text-[10px] text-zinc-500 font-medium tracking-tight\">El examen de la dominancia animal</p>\n            </div>\n          </div>\n\n          {/* Quick tab controllers */}\n          <nav className=\"flex space-x-1 bg-zinc-900/60 p-1 rounded-xl border border-zinc-900\">\n            {(\n              [\n                { id: \"grafo\", label: \"El Grafo\" },\n                { id: \"dialectica\", label: \"Tesis & Dilemas\" },\n                { id: \"calculadora\", label: \"El Cuantificador\" },\n                { id: \"validador\", label: \"Sitiens IA\" }\n              ] as { id: TabType; label: string }[]\n            ).map((tab) => (\n              <button\n                key={tab.id}\n                onClick={() => setActiveTab(tab.id)}\n                className={`px-3 py-1.5 rounded-lg text-xs font-medium tracking-tight transition-all duration-200 cursor-pointer ${\n                  activeTab === tab.id\n                    ? \"bg-zinc-800 text-white shadow-sm\"\n                    : \"text-zinc-400 hover:text-white hover:bg-zinc-900/50\"\n                }`}\n              >\n                {tab.label}\n              </button>\n            ))}\n          </nav>\n\n        </div>\n      </header>\n\n      {/* Main core layout wrapper */}\n      <main className=\"flex-1 max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-8 lg:py-12 relative z-10 space-y-12\">\n        \n        {/* Welcome Section */}\n        <AnimatePresence mode=\"wait\">\n          {activeTab === \"grafo\" && (\n            <motion.div\n              initial={{ opacity: 0, y: -10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -10 }}\n              transition={{ duration: 0.25 }}\n              className=\"space-y-4 max-w-4xl\"\n            >\n              <div className=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-zinc-900 border border-zinc-850\">\n                <span className=\"w-1.5 h-1.5 rounded-full bg-red-400 animate-pulse animate-duration-1500\" />\n                <span className=\"text-[10px] font-mono tracking-widest uppercase text-zinc-400 font-bold\">Iniciativa bio\303\251tica laica</span>\n              </div>\n              <h2 className=\"text-3xl sm:text-5xl font-black text-white tracking-tight leading-tight\">\n                \302\277Qu\303\251 vidas importan en la ecuaci\303\263n de la Tierra?\n              </h2>\n              <p className=\"text-zinc-400 text-sm md:text-base font-light leading-relaxed max-w-3xl\">\n                Sitiens explora, desglosa y deconstruye cr\303\255ticamente los l\303\255mites de la sintiencia animal, el recorrido hist\303\263rico de nuestra domesticaci\303\263n utilitaria, la termodin\303\241mica de nuestros h\303\241bitos alimentarios y los sesgos l\303\263gicos inconscientes que sostienen el specismo de mercado.\n              </p>\n            </motion.div>\n          )}\n        </AnimatePresence>\n\n        {/* Selected View Space */}\n        <div className=\"w-full\">\n          <AnimatePresence mode=\"wait\">\n            {activeTab === \"grafo\" && (\n              <motion.div\n                key=\"grafo\"\n                initial={{ opacity: 0, y: 15 }}\n                animate={{ opacity: 1, y: 0 }}\n                exit={{ opacity: 0, y: -15 }}\n                transition={{ duration: 0.25 }}\n                className=\"w-full\"\n              >\n                <NetworkGraph />\n              </motion.div>\n            )}\n\n            {activeTab === \"dialectica\" && (\n              <motion.div\n                key=\"dialectica\"\n                initial={{ opacity: 0, y: 15 }}\n                animate={{ opacity: 1, y: 0 }}\n                exit={{ opacity: 0, y: -15 }}\n                transition={{ duration: 0.25 }}\n                className=\"w-full\"\n              >\n                <ExcusesDilemmas onAnalyzeTrigger={handleDeconstructTrigger} />\n              </motion.div>\n            )}\n\n            {activeTab === \"calculadora\" && (\n              <motion.div\n                key=\"calculadora\"\n                initial={{ opacity: 0, y: 15 }}\n                animate={{ opacity: 1, y: 0 }}\n                exit={{ opacity: 0, y: -15 }}\n                transition={{ duration: 0.25 }}\n                className=\"w-full\"\n              >\n                <ImpactCalculator />\n              </motion.div>\n            )}\n\n            {activeTab === \"validador\" && (\n              <motion.div\n                key=\"validador\"\n                initial={{ opacity: 0, y: 15 }}\n                animate={{ opacity: 1, y: 0 }}\n                exit={{ opacity: 0, y: -15 }}\n                transition={{ duration: 0.25 }}\n                className=\"w-full\"\n              >\n                <AiValidator argumentToAnalyze={passedArgument} clearArgument={handleClearTrigger} />\n              </motion.div>\n            )}\n          </AnimatePresence>\n        </div>\n\n        {/* Dynamic Static Information Segment */}\n        {activeTab === \"grafo\" && (\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 pt-6\">\n            <div className=\"bg-zinc-950 p-6 border border-zinc-900 rounded-2xl space-y-2\">\n              <div className=\"flex items-center gap-2 mb-1\">\n                <span className=\"p-1 px-2 rounded bg-red-500/10 border border-red-500/20 text-[10px] font-mono text-red-400 font-bold\">1</span>\n                <span className=\"font-bold text-white text-xs\">Mapeo del dolor</span>\n              </div>\n              <p className=\"text-zinc-500 text-xs font-light leading-relaxed\">\n                Investiga las evidencias emp\303\255ricas sobre el sistema nervioso central, la presencia de dolor consciente y la deconstrucci\303\263n de la frontera vegetal.\n              </p>\n            </div>\n            <div className=\"bg-zinc-950 p-6 border border-zinc-900 rounded-2xl space-y-2\">\n              <div className=\"flex items-center gap-2 mb-1\">\n                <span className=\"p-1 px-2 rounded bg-emerald-500/10 border border-emerald-500/20 text-[10px] font-mono text-emerald-400 font-bold\">2</span>\n                <span className=\"font-bold text-white text-xs\">Soterrar el Desgaste</span>\n              </div>\n              <p className=\"text-zinc-500 text-xs font-light leading-relaxed\">\n                Analiza las variables de metano del ganado rumiante, la termodin\303\241mica ineficiente del filtrado de piensos y la deforestaci\303\263n de bosques para monocultivos de soja.\n              </p>\n            </div>\n            <div className=\"bg-zinc-950 p-6 border border-zinc-900 rounded-2xl space-y-2\">\n              <div className=\"flex items-center gap-2 mb-1\">\n                <span className=\"p-1 px-2 rounded bg-amber-500/10 border border-amber-500/20 text-[10px] font-mono text-amber-400 font-bold\">3</span>\n                <span className=\"font-bold text-white text-xs\">Deconstrucci\303\263n</span>\n              </div>\n              <p className=\"text-zinc-500 text-xs font-light leading-relaxed\">\n                Examina los dogmas y axiomas morales de nuestra cultura con una aproximaci\303\263n socr\303\241tica y asimila los recursos modernos de la suplementaci\303\263n de B12.\n              </p>\n            </div>\n          </div>\n        )}\n\n      </main>\n\n      {/* Simple, descriptive minimal footer */}\n      <footer className=\"border-t border-zinc-900/60 py-6 mt-16 bg-zinc-950\">\n        <div id=\"footer-section\" className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-4 text-[11px] font-mono text-zinc-650\">\n          <div className=\"flex items-center gap-1.5\">\n            <Heart className=\"w-3.5 h-3.5 text-zinc-700\" />\n            <span>Sitiens es un proyecto educativo de libre deconstrucci\303\263n moral.</span>\n          </div>\n          <div>\n            <span>Nutrido socr\303\241ticamente con neurobiolog\303\255a y f\303\255sica de ecosistemas.</span>\n          </div>\n        </div>\n      </footer>\n    </div>\n  );\n}"
    }
    diff {
      unified_diff {
        lines {
          text: "import { useState } from \"react\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
