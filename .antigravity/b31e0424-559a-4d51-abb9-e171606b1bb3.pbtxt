  file_change {
    absolute_path_uri: "file:///server.ts"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import express from \"express\";\nimport path from \"path\";\nimport { createServer as createViteServer } from \"vite\";\nimport { GoogleGenAI, Type } from \"@google/genai\";\nimport dotenv from \"dotenv\";\n\ndotenv.config();\n\nasync function startServer() {\n  const app = express();\n  const PORT = 3000;\n\n  app.use(express.json());\n\n  // API endpoints FIRST\n  app.post(\"/api/analyze-argument\", async (req, res): Promise<void> => {\n     try {\n        const { argument, context } = req.body;\n        if (!argument) {\n           res.status(400).json({ error: \"Argument is required\" });\n           return;\n        }\n\n        const apiKey = process.env.GEMINI_API_KEY;\n        if (!apiKey) {\n           res.status(500).json({ error: \"GEMINI_API_KEY environment variable is missing\" });\n           return;\n        }\n\n        // Initialize Gemini client inside endpoint (lazy loading)\n        const ai = new GoogleGenAI({\n           apiKey: apiKey,\n           httpOptions: {\n              headers: {\n                 \'User-Agent\': \'aistudio-build\',\n              }\n           }\n        });\n\n        const systemPrompt = `Eres un catedr\303\241tico de \303\251tica animal, deconstrucci\303\263n moral y biolog\303\255a evolutiva aplicada con un estilo dial\303\251ctico riguroso, intelectual y cl\303\255nico. Tu objetivo es desarmar las excusas, falacias, dogmas o justificaciones del usuario sobre comer carne, explotar animales para ocio o eludir su responsabilidad clim\303\241tica.\nNo intentes sonar moralista, sermoneador o recriminatorio. En su lugar, desarma su argumento f\303\241ctico y l\303\263gico utilizando pura neurobiolog\303\255a, termodin\303\241mica, antropolog\303\255a, f\303\255sica y dial\303\251ctica filos\303\263fica rigurosa. Hazlo ver que sus conclusiones a menudo se sostienen sobre axiomas no examinados.\n\nDebes responder estrictamente en formato JSON utilizando las claves indicadas en el siguiente esquema:\n{\n  \"argumentSummary\": \"Resumen conciso y honesto de la tesis o justificaci\303\263n planteada por el usuario\",\n  \"axioms\": [\"Principio o axioma impl\303\255cito en su justificaci\303\263n (por ejemplo, excepcionalismo moral humano, falacia de la cadena alimentaria, negaci\303\263n de la privaci\303\263n de experiencias futuras, etc.)\"],\n  \"scientificAccuracy\": {\n     \"rating\": \"Calificaci\303\263n de precisi\303\263n cient\303\255fica (por ejemplo: Falsa, Matizada, Obsoleta o Sesgada)\",\n     \"analysis\": \"Explicaci\303\263n biol\303\263gica, evolutiva, ecol\303\263gica o bioqu\303\255mica de por qu\303\251 el argumento no se sostiene hoy en d\303\255a (por ejemplo, la disponibilidad de B12 sint\303\251tica, la digestibilidad comparativa o la nocicepci\303\263n animal frente a la irritabilidad mec\303\241nica de las plantas).\"\n  },\n  \"logicalFailures\": [\"P\303\241rrafo que explore las falacias l\303\263gicas involucradas (por ejemplo: apelaci\303\263n a la naturaleza, falacia moralista de la tradici\303\263n, sesgo de confirmaci\303\263n, etc.) de forma l\303\263gica.\"],\n  \"impactAnalysis\": {\n     \"sintiente\": \"An\303\241lisis cuantitativo/cualitativo del sufrimiento f\303\241ctico, estr\303\251s o secuestro vital infligido al animal involucrado.\",\n     \"ecosistemic\": \"Explicaci\303\263n f\303\255sica y termodin\303\241mica del desgaste ecol\303\263gico colosal: ineficiencia de conversi\303\263n cal\303\263rica (hasta un 90% de p\303\251rdida por conversi\303\263n), uso masivo de agua dulce, emisiones antropog\303\251nicas de metano (CH4) y deforestaci\303\263n por forraje.\"\n  },\n  \"alternativeReflection\": \"Una reflexi\303\263n o pregunta socr\303\241tica final, sutilmente inc\303\263moda y desestabilizadora, que dejes en la mente del usuario para empujarlo a dudar de su justificaci\303\263n f\303\241ctica y moral.\"\n}`;\n\n        const prompt = `Analiza cr\303\255ticamente el siguiente argumento: \"${argument}\"\nContexto o categor\303\255a asociada: ${context || \"General\"}`;\n\n        const response = await ai.models.generateContent({\n           model: \"gemini-3.5-flash\",\n           contents: prompt,\n           config: {\n              systemInstruction: systemPrompt,\n              responseMimeType: \"application/json\",\n              responseSchema: {\n                 type: Type.OBJECT,\n                 properties: {\n                    argumentSummary: { type: Type.STRING },\n                    axioms: { type: Type.ARRAY, items: { type: Type.STRING } },\n                    scientificAccuracy: {\n                       type: Type.OBJECT,\n                       properties: {\n                          rating: { type: Type.STRING },\n                          analysis: { type: Type.STRING }\n                       },\n                       required: [\"rating\", \"analysis\"]\n                    },\n                    logicalFailures: { type: Type.ARRAY, items: { type: Type.STRING } },\n                    impactAnalysis: {\n                       type: Type.OBJECT,\n                       properties: {\n                          sintiente: { type: Type.STRING },\n                          ecosistemic: { type: Type.STRING }\n                       },\n                       required: [\"sintiente\", \"ecosistemic\"]\n                    },\n                    alternativeReflection: { type: Type.STRING }\n                 },\n                 required: [\n                    \"argumentSummary\", \n                    \"axioms\", \n                    \"scientificAccuracy\", \n                    \"logicalFailures\", \n                    \"impactAnalysis\", \n                    \"alternativeReflection\"\n                 ]\n              }\n           }\n        });\n\n        const text = response.text;\n        res.setHeader(\"Content-Type\", \"application/json\");\n        res.send(text || \"{}\");\n     } catch (err: any) {\n        console.error(\"Error calling Gemini API:\", err);\n        res.status(500).json({ \n           error: \"Error interno del servidor al procesar el an\303\241lisis\", \n           details: err?.message || err \n        });\n     }\n  });\n\n  // Serve static assets or mount Vite middleware in development\n  if (process.env.NODE_ENV !== \"production\") {\n    const vite = await createViteServer({\n      server: { middlewareMode: true },\n      appType: \"spa\",\n    });\n    app.use(vite.middlewares);\n  } else {\n    const distPath = path.join(process.cwd(), \'dist\');\n    app.use(express.static(distPath));\n    app.get(\'*\', (req, res) => {\n      res.sendFile(path.join(distPath, \'index.html\'));\n    });\n  }\n\n  app.listen(PORT, \"0.0.0.0\", () => {\n    console.log(`Server running on http://localhost:${PORT}`);\n  });\n}\n\nstartServer();\n"
    }
